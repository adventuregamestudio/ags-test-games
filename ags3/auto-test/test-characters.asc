// Test Characters Module Script
int GetTestCharactersCount()
{
  return 0
#ifver 3.6.3
  + 2 // 3.6.3 properties
#endif
  + 1 // graphic pos
  + 4 // view frames
  + 8 + 8  // direction loops and instant turning
  + 8 * 3  // face location
  + 12 * 3 // turn on spot animating (without diagonals)
  + 24 * 3 // turn on spot animating (with diagonals 1-frame)
  + 24 * 3 // turn on spot animating (with diagonals multiframe)
  + 76     // animation
  + 8 * 3  // idle start time
  + 12 * 3 // idle loop
  + 4      // idle interrupts
  + 12 * 3 // direct move
  + 7 // waypoints move
  ;
}

