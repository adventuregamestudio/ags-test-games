//-----------------------------------------------------------------------------
// TEST RENDER
//-----------------------------------------------------------------------------

//int test_render_num;
void _TestCharRenderF(Character *testChar, int sprite_num, eFlipDirection flip, const string test_name)
{
  Wait(1); // let engine redraw
  // IMPORTANT: AGS 3.* has a historical mistake where the object's sprite is drawn 1 pixel higher than necessary
  int sprite_w = Game.SpriteWidth[sprite_num];
  int sprite_h = Game.SpriteHeight[sprite_num];
  int sprite_x = testChar.x - sprite_w / 2;
  int sprite_y = testChar.y - sprite_h;
  //tap.Comment(String.Format("sprite_x = %d, sprite_y = %d, sprite_w = %d, sprite_h = %d", sprite_x, sprite_y, sprite_w, sprite_h));
  //SaveScreenShot(String.Format("_character_%d.bmp", test_render_num));
  //test_render_num++;
  tap.ok(GfxComparer.TakeScreenshotAndMatchSprite(sprite_x, sprite_y, sprite_w, sprite_h, sprite_num, flip), test_name);
}

void _TestCharRender(Character *testChar, int sprite_num, const string test_name)
{
  _TestCharRenderF(testChar, sprite_num, -1, test_name);
}

void _TestCharViewFrame(Character *testChar, int view, int loop, int frame, const string test_name)
{
  testChar.LockViewFrame(view, loop, frame);
  ViewFrame* vf = Game.GetViewFrame(view, loop, frame);
  eFlipDirection flip = -1;
  if (vf.Flipped)
    flip = eFlipLeftToRight;
  _TestCharRenderF(testChar, vf.Graphic, flip, test_name);
  testChar.UnlockView();
}

#define SPRITE_DEFAULT 9

void TestGraphicPosition()
{
  cWalker1.LockViewFrame(VFLIP, 0, 0);
  _TestCharRender(cWalker1, SPRITE_DEFAULT, "Character: graphic position");
  cWalker1.UnlockView();
}

void TestViewRender()
{
  _TestCharViewFrame(cWalker1, VFLIP, 0, 0, "Character: view frame 0, normal");
  _TestCharViewFrame(cWalker1, VFLIP, 0, 1, "Character: view frame 1, normal");
  _TestCharViewFrame(cWalker1, VFLIP, 0, 2, "Character: view frame 2, h-flip");
  _TestCharViewFrame(cWalker1, VFLIP, 0, 3, "Character: view frame 3, h-flip");
}

//-----------------------------------------------------------------------------
// TEST FACING AND TURNING
//-----------------------------------------------------------------------------

void TestChangingDirectionLoop()
{
  Character* turner = cWalker2;
  turner.ChangeRoom(player.Room);
  turner.ChangeView(VWALKING2);
  
  turner.Loop = eDirectionDown;
  tap.is_int(turner.Loop, 0, "Character Loop is 0 (down)");
  turner.Loop = eDirectionLeft;
  tap.is_int(turner.Loop, 1, "Character Loop is 1 (left)");
  turner.Loop = eDirectionRight;
  tap.is_int(turner.Loop, 2, "Character Loop is 2 (right)");
  turner.Loop = eDirectionUp;
  tap.is_int(turner.Loop, 3, "Character Loop is 3 (up)");
  turner.Loop = eDirectionDownRight;
  tap.is_int(turner.Loop, 4, "Character Loop is 4 (down-right)");
  turner.Loop = eDirectionUpRight;
  tap.is_int(turner.Loop, 5, "Character Loop is 5 (up-right)");
  turner.Loop = eDirectionDownLeft;
  tap.is_int(turner.Loop, 6, "Character Loop is 6 (down-left)");
  turner.Loop = eDirectionUpLeft;
  tap.is_int(turner.Loop, 7, "Character Loop is 7 (up-left)");
}

void TestTurnOnSpotInstant()
{
  Character* turner = cWalker2;
  turner.ChangeRoom(player.Room);
  turner.ChangeView(VWALKING2);
  turner.Loop = eDirectionDown;
  SetGameOption(OPT_TURNWHENFACING, 0);
  
  turner.FaceDirection(eDirectionDown);
  tap.is_int(turner.Loop, 0, "Character.FaceDirection: down (instant)");
  turner.FaceDirection(eDirectionLeft);
  tap.is_int(turner.Loop, 1, "Character.FaceDirection: left (instant)");
  turner.FaceDirection(eDirectionRight);
  tap.is_int(turner.Loop, 2, "Character.FaceDirection: right (instant)");
  turner.FaceDirection(eDirectionUp);
  tap.is_int(turner.Loop, 3, "Character.FaceDirection: up (instant)");
  turner.FaceDirection(eDirectionDownRight);
  tap.is_int(turner.Loop, 4, "Character.FaceDirection: down-right (instant)");
  turner.FaceDirection(eDirectionUpRight);
  tap.is_int(turner.Loop, 5, "Character.FaceDirection: up-right (instant)");
  turner.FaceDirection(eDirectionDownLeft);
  tap.is_int(turner.Loop, 6, "Character.FaceDirection: down-left (instant)");
  turner.FaceDirection(eDirectionUpLeft);
  tap.is_int(turner.Loop, 7, "Character.FaceDirection: up-left (instant)");
}

void TestFaceLocationImpl(Character* turner, bool expect_diag, String test_name)
{
  turner.x = 100;
  turner.y = 100;
  
  turner.FaceLocation(turner.x, turner.y + 100);
  tap.is_int(turner.Loop, 0, String.Format("%s: down", test_name));
  turner.FaceLocation(turner.x - 100, turner.y);
  tap.is_int(turner.Loop, 1, String.Format("%s: left", test_name));
  turner.FaceLocation(turner.x + 100, turner.y);
  tap.is_int(turner.Loop, 2, String.Format("%s: right", test_name));
  turner.FaceLocation(turner.x, turner.y - 100);
  tap.is_int(turner.Loop, 3, String.Format("%s: up", test_name));
  if (expect_diag)
  {
    turner.FaceLocation(turner.x + 100, turner.y + 100);
    tap.is_int(turner.Loop, 4, String.Format("%s: down-right", test_name));
    turner.FaceLocation(turner.x + 100, turner.y - 100);
    tap.is_int(turner.Loop, 5, String.Format("%s: up-right", test_name));
    turner.FaceLocation(turner.x - 100, turner.y + 100);
    tap.is_int(turner.Loop, 6, String.Format("%s: down-left", test_name));
    turner.FaceLocation(turner.x - 100, turner.y - 100);
    tap.is_int(turner.Loop, 7, String.Format("%s: up-left", test_name));
  }
  else
  {
    turner.FaceLocation(turner.x + 100, turner.y + 100);
    tap.is_int(turner.Loop, 0, String.Format("%s: down-right (should be down)", test_name));
    turner.FaceLocation(turner.x + 100, turner.y - 100);
    tap.is_int(turner.Loop, 3, String.Format("%s: up-right (should be up)", test_name));
    turner.FaceLocation(turner.x - 100, turner.y + 100);
    tap.is_int(turner.Loop, 0, String.Format("%s: down-left (should be down)", test_name));
    turner.FaceLocation(turner.x - 100, turner.y - 100);
    tap.is_int(turner.Loop, 3, String.Format("%s: up-left (should be up)", test_name));
  }
}

void TestFaceLocation()
{
  Character* turner = cWalker2;
  turner.ChangeRoom(player.Room);
  turner.DiagonalLoops = true; // engine will still test the presence of loops in View
  SetGameOption(OPT_TURNWHENFACING, 0);
  
  // No diagonal loops
  turner.ChangeView(VWALKING_NODIAG);
  TestFaceLocationImpl(turner, false, "Character.FaceLocation (no diag)");
  
  // Diagonal loops with only 1 frame
  // NOTE: for some reason FaceLocation requires diagonal loops having full animation (> 1 frame)
  turner.ChangeView(VWALKING_DIAG1FRAME);
  TestFaceLocationImpl(turner, false, "Character.FaceLocation (diag w 1 frame)");
  
  // Diagonal loops with animation
  turner.ChangeView(VWALKING2);
  TestFaceLocationImpl(turner, true, "Character.FaceLocation (diag proper)");
}

void TestSingleTurn(Character *turner, String test_name, String step_name, 
  CharacterDirection from_dir, CharacterDirection next_dir,
  bool is_first_step)
{
  CharacterDirection cur_dir = turner.Loop;
  //tap.Comment(String.Format("loop before = %d", turner.Loop));
  tap.is_int(cur_dir, from_dir, String.Format("%s (%s): starting loop", test_name, step_name));
  // NOTE: turning speed = character's walk animation speed
  int turn_speed;
  // NOTE: engine does not wait before the very first turn step
  if (is_first_step)
    turn_speed = 0;
  else
    turn_speed = turner.AnimationSpeed;
  int turn_delay = turn_speed + 1; // if speed is 0, there will be still 1 tick to update the turn

  // Start with the wait, then increase a tick;
  // character switches to the next loop at the final tick
  int ticks_till_turn = 0;
  while (cur_dir == turner.Loop)
  {
    Wait(1);
    ticks_till_turn++;
  }
  //tap.Comment(String.Format("loop after = %d", turner.Loop));
  tap.is_int(ticks_till_turn, turn_delay, String.Format("%s (%s): delay ticks", test_name, step_name));
  tap.is_int(turner.Loop, next_dir, String.Format("%s (%s): changed to next loop", test_name, step_name));
}

void TestTurnOnSpotAnimatingNoDiag(Character* turner, String test_name)
{
  turner.Loop = eDirectionDown;
  
  // Quarter-circle turns
  // Clockwise
  turner.FaceDirection(eDirectionLeft, eNoBlock);
  TestSingleTurn(turner, test_name, "down->left cw : down->left", eDirectionDown, eDirectionLeft, true);
  turner.FaceDirection(eDirectionUp, eNoBlock);
  TestSingleTurn(turner, test_name, "left->up cw : left->up", eDirectionLeft, eDirectionUp, true);
  turner.FaceDirection(eDirectionRight, eNoBlock);
  TestSingleTurn(turner, test_name, "up->right cw : up->right", eDirectionUp, eDirectionRight, true);
  turner.FaceDirection(eDirectionDown, eNoBlock);
  TestSingleTurn(turner, test_name, "right->down cw : right->down", eDirectionRight, eDirectionDown, true);
  // Counter-Clockwise
  turner.FaceDirection(eDirectionRight, eNoBlock);
  TestSingleTurn(turner, test_name, "down->right ccw : down->right", eDirectionDown, eDirectionRight, true);
  turner.FaceDirection(eDirectionUp, eNoBlock);
  TestSingleTurn(turner, test_name, "right->up ccw : right->up", eDirectionRight, eDirectionUp, true);
  turner.FaceDirection(eDirectionLeft, eNoBlock);
  TestSingleTurn(turner, test_name, "up->left ccw : up->left", eDirectionUp, eDirectionLeft, true);
  turner.FaceDirection(eDirectionDown, eNoBlock);
  TestSingleTurn(turner, test_name, "left->down ccw : left->down", eDirectionLeft, eDirectionDown, true);
  
  // Half-circle turns
  // Down->Up
  turner.Loop = eDirectionDown;
  turner.FaceDirection(eDirectionUp, eNoBlock);
  TestSingleTurn(turner, test_name, "down->up cw : down->left", eDirectionDown, eDirectionLeft, true);
  TestSingleTurn(turner, test_name, "down->up cw : left->up", eDirectionLeft, eDirectionUp, false);
  // Left->Right
  turner.Loop = eDirectionLeft;
  turner.FaceDirection(eDirectionRight, eNoBlock);
  TestSingleTurn(turner, test_name, "left->right cw : left->up", eDirectionLeft, eDirectionUp, true);
  TestSingleTurn(turner, test_name, "left->right cw : up->right", eDirectionUp, eDirectionRight, false);
}

void TestTurnOnSpotAnimatingWithDiag(Character* turner, String test_name)
{
  turner.Loop = eDirectionDown;
  
  // Quarter-circle turns
  // Clockwise
  turner.FaceDirection(eDirectionLeft, eNoBlock);
  TestSingleTurn(turner, test_name, "down->left cw : down->downleft", eDirectionDown, eDirectionDownLeft, true);
  TestSingleTurn(turner, test_name, "down->left cw : downleft->left", eDirectionDownLeft, eDirectionLeft, false);
  turner.FaceDirection(eDirectionUp, eNoBlock);
  TestSingleTurn(turner, test_name, "left->up cw : left->upleft", eDirectionLeft, eDirectionUpLeft, true);
  TestSingleTurn(turner, test_name, "left->up cw : upleft->up", eDirectionUpLeft, eDirectionUp, false);
  turner.FaceDirection(eDirectionRight, eNoBlock);
  TestSingleTurn(turner, test_name, "up->right cw : up->upright", eDirectionUp, eDirectionUpRight, true);
  TestSingleTurn(turner, test_name, "up->right cw : upright->right", eDirectionUpRight, eDirectionRight, false);
  turner.FaceDirection(eDirectionDown, eNoBlock);
  TestSingleTurn(turner, test_name, "right->down cw : right->downright", eDirectionRight, eDirectionDownRight, true);
  TestSingleTurn(turner, test_name, "right->down cw : downright->down", eDirectionDownRight, eDirectionDown, false);
  // Counter-Clockwise
  turner.FaceDirection(eDirectionRight, eNoBlock);
  TestSingleTurn(turner, test_name, "down->right ccw : down->downright", eDirectionDown, eDirectionDownRight, true);
  TestSingleTurn(turner, test_name, "down->right ccw : downright->right", eDirectionDownRight, eDirectionRight, false);
  turner.FaceDirection(eDirectionUp, eNoBlock);
  TestSingleTurn(turner, test_name, "right->up ccw : right->upright", eDirectionRight, eDirectionUpRight, true);
  TestSingleTurn(turner, test_name, "right->up ccw : upright->up", eDirectionUpRight, eDirectionUp, false);
  turner.FaceDirection(eDirectionLeft, eNoBlock);
  TestSingleTurn(turner, test_name, "up->left ccw : up->upleft", eDirectionUp, eDirectionUpLeft, true);
  TestSingleTurn(turner, test_name, "up->left ccw : upleft->left", eDirectionUpLeft, eDirectionLeft, false);
  turner.FaceDirection(eDirectionDown, eNoBlock);
  TestSingleTurn(turner, test_name, "left->down ccw : left->downleft", eDirectionLeft, eDirectionDownLeft, true);
  TestSingleTurn(turner, test_name, "left->down ccw : downleft->down", eDirectionDownLeft, eDirectionDown, false);
  
  // Half-circle turns
  // Down->Up
  turner.Loop = eDirectionDown;
  turner.FaceDirection(eDirectionUp, eNoBlock);
  TestSingleTurn(turner, test_name, "down->up cw : down->downleft", eDirectionDown, eDirectionDownLeft, true);
  TestSingleTurn(turner, test_name, "down->up cw : downleft->left", eDirectionDownLeft, eDirectionLeft, false);
  TestSingleTurn(turner, test_name, "down->up cw : left->upleft", eDirectionLeft, eDirectionUpLeft, false);
  TestSingleTurn(turner, test_name, "down->up cw : upleft->up", eDirectionUpLeft, eDirectionUp, false);
  // Left->Right
  turner.Loop = eDirectionLeft;
  turner.FaceDirection(eDirectionRight, eNoBlock);
  TestSingleTurn(turner, test_name, "left->right cw : left->upleft", eDirectionLeft, eDirectionUpLeft, true);
  TestSingleTurn(turner, test_name, "left->right cw : upleft->up", eDirectionUpLeft, eDirectionUp, false);
  TestSingleTurn(turner, test_name, "left->right cw : up->upright", eDirectionUp, eDirectionUpRight, false);
  TestSingleTurn(turner, test_name, "left->right cw : upright->right", eDirectionUpRight, eDirectionRight, false);
}

void TestTurnOnSpotAnimating()
{
  Character* turner = cWalker2;
  turner.ChangeRoom(player.Room);
  turner.DiagonalLoops = true; // engine will still test the presence of loops in View
  turner.AnimationSpeed = 5; // turning speed = anim speed
  turner.TurnWhenFacing = true;
  SetGameOption(OPT_TURNWHENFACING, 1);
  
  turner.ChangeView(VWALKING_NODIAG);
  TestTurnOnSpotAnimatingNoDiag(turner, "Character turn no diag");
  
  turner.ChangeView(VWALKING_DIAG1FRAME);
  TestTurnOnSpotAnimatingWithDiag(turner, "Character turn with 1 frame diag");
  
  turner.ChangeView(VWALKING2);
  TestTurnOnSpotAnimatingWithDiag(turner, "Character turn with diag");
}

//-----------------------------------------------------------------------------
// TEST ANIMATING
//-----------------------------------------------------------------------------

#define VANIMATE_LOOP_NORMAL 0
#define VANIMATE_LOOP_EMPTY  1
#define VANIMATE_LOOP_RUNNEXTLOOP_START 2
#define VANIMATE_LOOP_RUNNEXTLOOP_END   3
#define VANIMATE_LOOP_RUNNEXTLOOP_1_DELAY (1+2+3+4+5)
#define VANIMATE_LOOP_RUNNEXTLOOP_2_DELAY 4

int WaitTillNextFrame(Character* animator)
{
  int count;
  int frame = animator.Frame;
  while (animator.Animating && animator.Frame == frame)
  {
    Wait(1);
    count++;
  }
  return count;
}

int WaitTillNextLoop(Character* animator)
{
  int count;
  int loop = animator.Loop;
  while (animator.Animating && animator.Loop == loop)
  {
    Wait(1);
    count++;
  }
  return count;
}

void TestAnimateImpl(Character* animator, Direction dir, int sframe, String test_name)
{
  animator.Animate(VANIMATE_LOOP_NORMAL, 0, eOnce, eNoBlock, dir, sframe); 
  tap.ok(animator.Animating, String.Format("%s: begin", test_name));
  tap.is_int(animator.View, VANIMATE, String.Format("%s: view", test_name));
  tap.is_int(animator.Loop, VANIMATE_LOOP_NORMAL, String.Format("%s: loop", test_name));
  if (dir == eForwards)
  {
    if (sframe == 0)
    {
      tap.is_int(animator.Frame, 0, String.Format("%s: frame 0", test_name));
      tap.is_int(WaitTillNextFrame(animator), 1, String.Format("%s: frame 0 delay", test_name));
    }
    if (sframe <= 1)
    {
      tap.is_int(animator.Frame, 1, String.Format("%s: frame 1", test_name));
      tap.is_int(WaitTillNextFrame(animator), 2, String.Format("%s: frame 1 delay", test_name));
    }
    if (sframe <= 2)
    {
      tap.is_int(animator.Frame, 2, String.Format("%s: frame 2", test_name));
      tap.is_int(WaitTillNextFrame(animator), 3, String.Format("%s: frame 2 delay", test_name));
    }
    if (sframe <= 3)
    {
      tap.is_int(animator.Frame, 3, String.Format("%s: frame 3", test_name));
      tap.is_int(WaitTillNextFrame(animator), 4, String.Format("%s: frame 3 delay", test_name));
    }
    if (sframe <= 4)
    {
      tap.is_int(animator.Frame, 4, String.Format("%s: frame 4", test_name));
      tap.is_int(WaitTillNextFrame(animator), 5, String.Format("%s: frame 4 delay", test_name));
    }
  }
  else
  {
    sframe--;
    if (sframe < 0)
      sframe = 4;

    if (sframe == 4)
    {
      tap.is_int(animator.Frame, 4, String.Format("%s: frame 4", test_name));
      tap.is_int(WaitTillNextFrame(animator), 5, String.Format("%s: frame 4 delay", test_name));
    }
    if (sframe >= 3)
    {
      tap.is_int(animator.Frame, 3, String.Format("%s: frame 3", test_name));
      tap.is_int(WaitTillNextFrame(animator), 4, String.Format("%s: frame 3 delay", test_name));
    }
    if (sframe >= 2)
    {
      tap.is_int(animator.Frame, 2, String.Format("%s: frame 2", test_name));
      tap.is_int(WaitTillNextFrame(animator), 3, String.Format("%s: frame 2 delay", test_name));
    }
    if (sframe >= 1)
    {
      tap.is_int(animator.Frame, 1, String.Format("%s: frame 1", test_name));
      tap.is_int(WaitTillNextFrame(animator), 2, String.Format("%s: frame 1 delay", test_name));
    }
    if (sframe >= 0)
    {
      tap.is_int(animator.Frame, 0, String.Format("%s: frame 0", test_name));
      tap.is_int(WaitTillNextFrame(animator), 1, String.Format("%s: frame 0 delay", test_name));
    }
  }
  
  tap.ok(!animator.Animating, String.Format("%s: end", test_name));
}

void TestRepeatedAnimateImpl(Character* animator, Direction dir, String test_name)
{
  animator.LockView(VANIMATE);
  animator.Animate(VANIMATE_LOOP_NORMAL, 0, eRepeat, eNoBlock, dir, 0);
  tap.is_int(animator.View, VANIMATE, String.Format("%s: view", test_name));
  tap.ok(animator.Animating, String.Format("%s: begin", test_name));
  if (dir == eForwards)
  {
    tap.is_int(animator.Frame, 0, String.Format("%s: frame 0", test_name));
    while (animator.Frame != 4) { Wait(1); }
    tap.is_int(animator.Frame, 4, String.Format("%s: frame 4", test_name));
    WaitTillNextFrame(animator);
    tap.is_int(animator.Frame, 0, String.Format("%s: run and repeated to frame 0", test_name));
  }
  else
  {
    tap.is_int(animator.Frame, 4, String.Format("%s: frame 4", test_name));
    while (animator.Frame != 0) { Wait(1); }
    tap.is_int(animator.Frame, 0, String.Format("%s: frame 0", test_name));
    WaitTillNextFrame(animator);
    tap.is_int(animator.Frame, 4, String.Format("%s: run and repeated to frame 4", test_name));
  }
  
  animator.UnlockView();
  tap.ok(!animator.Animating, String.Format("%s: end", test_name));
}

void TestAnimate()
{
  Character* animator = cWalker1;
  animator.LockView(VANIMATE);
  tap.is_int(animator.View, VANIMATE, "Character.LockView: view");
  tap.is_int(animator.Loop, 0, "Character.LockView: loop");
  tap.is_int(animator.Frame, 0, "Character.LockView: frame");
  
  // Test animation frame by frame, checking delays too
  // Normal run
  TestAnimateImpl(animator, eForwards, 0, "Character.Animate");
  // Start at frame > 0
  TestAnimateImpl(animator, eForwards, 2, "Character.Animate (start frame)");
  // Go backwards
  TestAnimateImpl(animator, eBackwards, 0, "Character.Animate (backwards)");
  // Go backwards, start at frame < last
  TestAnimateImpl(animator, eBackwards, 3, "Character.Animate (backwards, start frame)");
  animator.UnlockView();
  
  TestRepeatedAnimateImpl(animator, eForwards, "Character.Animate (repeat forwards)");
  TestRepeatedAnimateImpl(animator, eBackwards, "Character.Animate (repeat backwards)");
  animator.UnlockView(); // just in case
  
  // Empty loop (should just display a placeholder frame)
  animator.LockView(VANIMATE);
  animator.Animate(VANIMATE_LOOP_EMPTY, 0, eOnce, eNoBlock);
  tap.ok(animator.Animating, "Character.Animate (empty loop): begin");
  tap.is_int(animator.View, VANIMATE, "Character.Animate (empty loop): view");
  tap.is_int(animator.Loop, VANIMATE_LOOP_EMPTY, "Character.Animate (empty loop): loop");
  tap.is_int(animator.Frame, 0, "Character.Animate (empty loop): frame placeholder");
  tap.is_int(WaitTillNextFrame(animator), 1, "Character.Animate (empty loop): frame delay");
  tap.ok(!animator.Animating, "Character.Animate (empty loop): end");
  animator.UnlockView();
  
  // Run loop sequence
  animator.LockView(VANIMATE);
  animator.Animate(VANIMATE_LOOP_RUNNEXTLOOP_START, 0, eOnce, eNoBlock);
  tap.ok(animator.Animating, "Character.Animate (loop sequence): begin");
  tap.is_int(animator.View, VANIMATE, "Character.Animate (loop sequence): view");
  tap.is_int(animator.Loop, VANIMATE_LOOP_RUNNEXTLOOP_START, "Character.Animate (loop sequence): first loop");
  tap.is_int(WaitTillNextLoop(animator), VANIMATE_LOOP_RUNNEXTLOOP_1_DELAY, "Character.Animate (loop sequence): first loop time");
  tap.is_int(animator.Loop, VANIMATE_LOOP_RUNNEXTLOOP_END, "Character.Animate (loop sequence): second loop");
  tap.is_int(WaitTillNextLoop(animator), VANIMATE_LOOP_RUNNEXTLOOP_2_DELAY, "Character.Animate (loop sequence): second loop time");
  tap.ok(!animator.Animating, "Character.Animate (loop sequence): end");
  animator.UnlockView();
}

//-----------------------------------------------------------------------------
// TEST IDLING
//-----------------------------------------------------------------------------

import void TestIdleStartsInTime(Character* idler, int idle_start_delay, String test_name, int skip_ticks = 0, bool after_action = false);

void TestIdleStartsInTime(Character* idler, int idle_start_delay, String test_name, int skip_ticks, bool after_action)
{
  // Idle start timer is calculated in *seconds* rather than game ticks.
  int game_speed = GetGameSpeed();
  int idle_time = idle_start_delay * game_speed - skip_ticks;
  // NOTE: undocumented, but AGS does not decrement idle timer on each tick, 
  // instead it decrements whole second each game second, using seconds counted from
  // the *game's start*, rather than seconds counted from the last character action.
  int second_ticks_passed = GT.GameTicks % game_speed;
  idle_time -= second_ticks_passed;
  //tap.Comment(String.Format("second_ticks_passed = %d", second_ticks_passed));
  
  // Also then it actually waits for 1 more second before starting idle view!
  // --- Except when NOT after action!
  if (!after_action)
  {
    idle_time += game_speed;
  }
  idle_time = idle_time + 1; // if speed is 0, there will be still 1 tick to update the idle timer
  
  tap.isnt_int(idler.View, idler.IdleView, String.Format("Character idle start (%s): before idling", test_name));
  int ticks_till_idle = 0;
  while (idler.View != idler.IdleView)
  {
    Wait(1);
    ticks_till_idle++;
  }
  //tap.Comment(String.Format("idle_time = %d, ticks_till_idle = %d", idle_time, ticks_till_idle));
  tap.is_int(ticks_till_idle, idle_time, String.Format("Character idle start (%s): delay ticks", test_name));
  tap.is_int(idler.View, idler.IdleView, String.Format("Character idle start (%s): started idling", test_name));
}

//
// Test that IdleView animation begins when certain time passes after the character action.
// FIXME: receive game speed as a parameter, because GetGameSpeed is unreliable with 1000+ values.
//
void TestIdleViewStart()
{
  Character* idler = cWalker1;
  idler.ChangeRoom(player.Room);
  int idle_start_delay = 1; // in seconds
  idler.SetIdleView(VIDLING, idle_start_delay);
  
  // NOTE: there's no property to return starting delay, so we pass that value as an argument
  TestIdleStartsInTime(idler, idle_start_delay, "initial", 0, true); // NOTE: previous tests had actions
  // Wait till current idle anim completes
  while (idler.View == idler.IdleView)
  {
    Wait(1);
  }
  TestIdleStartsInTime(idler, idle_start_delay, "after previous idle", 0, true);
    // note previous idling counts as action too, resetting idle timer by -1 s
  
  idler.Walk(idler.x - 10, idler.y, eBlock, eAnywhere);
  TestIdleStartsInTime(idler, idle_start_delay, "after walk", 0, true);
  
  SetGameOption(OPT_TURNWHENFACING, 0);
  idler.TurnBeforeWalking = false;
  idler.FaceDirection(eDirectionRight);
  TestIdleStartsInTime(idler, idle_start_delay, "after turn instant", 0, true);
  
  SetGameOption(OPT_TURNWHENFACING, 1);
  idler.TurnBeforeWalking = true;
  idler.FaceDirection(eDirectionLeft);
  TestIdleStartsInTime(idler, idle_start_delay, "after turn animated", 0, true);
  
  // Blocking say without speech view: idling is ticking and playing
  idle_start_delay = 2; // temporarily increase to 2 seconds, or the idling will begin right as speech is played
  idler.SetIdleView(VIDLING, idle_start_delay);
  Speech.SkipStyle = eSkipTime;
  idler.SpeechView = -1;
  int last_game_ticks = GT.GameTicks;
  idler.Say("x");
  TestIdleStartsInTime(idler, idle_start_delay, "after blocking say no view", GT.GameTicks - last_game_ticks, true);
    // note previous idling counts as action too, resetting idle timer by -1 s
  
  // Blocking say with speech view: idling is inactive
  idle_start_delay = 1; // in seconds
  idler.SetIdleView(VIDLING, idle_start_delay);
  idler.SpeechView = VSPEAKING;
  idler.Say("x");
  TestIdleStartsInTime(idler, idle_start_delay, "after blocking say has view", 0, true);
  
  idler.LockView(VANIMATE);
  idler.Animate(0, 0, eOnce, eBlock);
  idler.UnlockView();
  TestIdleStartsInTime(idler, idle_start_delay, "after custom animate", 0, true);
}

void TestIdleViewInterrupt()
{
  // Test that idle view is interrupted, - or NOT interrupted, 
  // by certain events
  
  // make a simple walkable area
  DrawingSurface* ds = GetDrawingSurfaceForWalkableArea();
  ds.DrawingColor = 1;
  ds.DrawRectangle(100, 100, 110, 110);
  ds.Release();
  
  Character* idler = cWalker1;
  idler.Solid = false; // avoid messing with other solid objects
  idler.ChangeView(VWALKING2);
  idler.ChangeRoom(player.Room, 100, 100);
  idler.SetIdleView(VIDLING, 0); // continuous idling
  
  Wait(1);
  tap.is_int(idler.View, VIDLING, "Character idle: continuous idling starts immediately");
  idler.Walk(100, 100, eNoBlock, eWalkableAreas);
  Wait(1);
  tap.is_int(idler.View, VIDLING, "Character idle: walk cmd to the character's current pos should not interrupt idling");
  idler.Walk(99, 99, eNoBlock, eWalkableAreas);
  Wait(1);
  tap.is_int(idler.View, VIDLING, "Character idle: walk cmd failing to find path should not interrupt idling");
  idler.Walk(105, 105, eNoBlock, eWalkableAreas);
  Wait(1);
  tap.is_int(idler.View, VWALKING2, "Character idle: interrupted by a normal walk");
  idler.StopMoving();
}

void TestIdleViewLoopImpl(Character* idler, int loop, String test_name)
{
  idler.FaceDirection(loop);
  tap.is_int(idler.Loop, loop, String.Format("%s: normal loop before idle", test_name));
  while (idler.View != idler.IdleView) { Wait(1); }
  tap.is_int(idler.Loop, loop, String.Format("%s: idle loop", test_name));
  while (idler.View == idler.IdleView) { Wait(1); }
  tap.is_int(idler.Loop, loop, String.Format("%s: back to normal loop", test_name));
}

void TestIdleViewLoop()
{
  Character* idler = cWalker1;
  idler.ChangeRoom(player.Room);
  idler.ChangeView(VWALKING2);
  idler.DiagonalLoops = true;
  idler.TurnWhenFacing = false;
  SetGameOption(OPT_TURNWHENFACING, 0);
  int idle_start_delay = 1; // in seconds
  
  // Test orthogonal directions
  idler.SetIdleView(VIDLING, idle_start_delay);
  TestIdleViewLoopImpl(idler, eDirectionDown, "Character idle loop (down)");
  TestIdleViewLoopImpl(idler, eDirectionLeft, "Character idle loop (left)");
  TestIdleViewLoopImpl(idler, eDirectionRight, "Character idle loop (right)");
  TestIdleViewLoopImpl(idler, eDirectionUp, "Character idle loop (up)");
  
  // Idle view with 1-frame diagonal loops
  idler.SetIdleView(VIDLING_DIAG1FRAME, idle_start_delay);
  TestIdleViewLoopImpl(idler, eDirectionDownRight, "Character idle loop (down-right, 1 frame)");
  TestIdleViewLoopImpl(idler, eDirectionUpRight, "Character idle loop (up-right, 1 frame)");
  TestIdleViewLoopImpl(idler, eDirectionDownLeft, "Character idle loop (down-left, 1 frame)");
  TestIdleViewLoopImpl(idler, eDirectionUpLeft, "Character idle loop (up-left, 1 frame)");
  
  // Idle view with multiframe diagonal loops
  idler.SetIdleView(VIDLING, idle_start_delay);
  TestIdleViewLoopImpl(idler, eDirectionDownRight, "Character idle loop (down-right, multi-frame)");
  TestIdleViewLoopImpl(idler, eDirectionUpRight, "Character idle loop (up-right, multi-frame)");
  TestIdleViewLoopImpl(idler, eDirectionDownLeft, "Character idle loop (down-left, multi-frame)");
  TestIdleViewLoopImpl(idler, eDirectionUpLeft, "Character idle loop (up-left, multi-frame)");
}

//-----------------------------------------------------------------------------
// TEST MOVING AND WALKING
//-----------------------------------------------------------------------------

void TestMoveDirect(Character* walker, String test_name, int sx, int sy, int dx, int dy, bool use_walk, BlockingStyle style)
{
  walker.x = sx;
  walker.y = sy;
  if (use_walk)
  {
    walker.Walk(dx, dy, style, eAnywhere);
  }
  else
  {
    walker.Move(dx, dy, style, eAnywhere);
  }
  if (style == eNoBlock)
  {
    while (walker.Moving) Wait(1);
  }
  tap.ok(!walker.Moving, String.Format("%s: finished move", test_name));
  tap.is_int(walker.x, dx, String.Format("%s: destination x", test_name));
  tap.is_int(walker.y, dy, String.Format("%s: destination y", test_name));
}

void TestMoveDirectToWaypoint(Character* walker, String test_name, int p_start, int p_end, int t_const, bool x_axis)
{
  int p_range1, p_range2;
  if (p_start <= p_end)
  {
    p_range1 = p_start;
    p_range2 = p_end;
  }
  else
  {
    p_range1 = p_end;
    p_range2 = p_start;
  }
  
  bool p_coords_in_range = true;
  bool t_coords_const = true;
  while (walker.Moving && (x_axis && walker.x != p_end) || (!x_axis && walker.y != p_end))
  {
    if (x_axis)
    {
      if (!(walker.x >= p_range1 && walker.x <= p_range2))
      {
        p_coords_in_range = false;
      }
      if (walker.x != p_end && walker.y != t_const)
      {
        t_coords_const = false;
      }
    }
    else
    {
      if (!(walker.y >= p_range1 && walker.y <= p_range2))
      {
        p_coords_in_range = false;
      }
      if (walker.y != p_end && walker.x != t_const)
      {
        t_coords_const = false;
      }
    }
    
    Wait(1);
  }
  tap.ok(p_coords_in_range && t_coords_const, String.Format("%s: move position stayed in range", test_name));
  // NOTE: we cannot test exact coords here, because character may already be turned and start moving towards next waypoint
}

// Tests moving and walking WITHOUT pathfinding (eAnywhere), 
// only for the sake of testing the fact of movement itself.
void TestSimpleMovement(Character* walker)
{
  // Move
  TestMoveDirect(walker, "Character.Move eBlock Hor", 0, 0, 100, 0, false, eBlock);
  TestMoveDirect(walker, "Character.Move eBlock Ver", 0, 0, 0, 100, false, eBlock);
  TestMoveDirect(walker, "Character.Move eBlock Diag", 0, 0, 100, 100, false, eBlock);
  TestMoveDirect(walker, "Character.Move eNoBlock Hor", 0, 0, 100, 0, false, eNoBlock);
  TestMoveDirect(walker, "Character.Move eNoBlock Ver", 0, 0, 0, 100, false, eNoBlock);
  TestMoveDirect(walker, "Character.Move eNoBlock Diag", 0, 0, 100, 100, false, eNoBlock);
  // Walk
  TestMoveDirect(walker, "Character.Walk eBlock Hor", 0, 0, 100, 0, true, eBlock);
  TestMoveDirect(walker, "Character.Walk eBlock Ver", 0, 0, 0, 100, true, eBlock);
  TestMoveDirect(walker, "Character.Walk eBlock Diag", 0, 0, 100, 100, true, eBlock);
  TestMoveDirect(walker, "Character.Walk eNoBlock Hor", 0, 0, 100, 0, true, eNoBlock);
  TestMoveDirect(walker, "Character.Walk eNoBlock Ver", 0, 0, 0, 100, true, eNoBlock);
  TestMoveDirect(walker, "Character.Walk eNoBlock Diag", 0, 0, 100, 100, true, eNoBlock);
  
  // AddWaypoint
  walker.x = 0;
  walker.y = 0;
  walker.AddWaypoint(100, 0);
  walker.AddWaypoint(100, 100);
  walker.AddWaypoint(0, 100);
  walker.AddWaypoint(0, 0);
  TestMoveDirectToWaypoint(walker, "Character.AddWaypoint 0,0->1,0", 0, 100, 0, true);
  TestMoveDirectToWaypoint(walker, "Character.AddWaypoint 1,0->1,1", 0, 100, 100, false);
  TestMoveDirectToWaypoint(walker, "Character.AddWaypoint 1,1->0,1", 100, 0, 100, true);
  TestMoveDirectToWaypoint(walker, "Character.AddWaypoint 0,1->0,0", 100, 0, 0, false);
  tap.ok(!walker.Moving, String.Format("%s: finished move", "Character.AddWaypoint"));
  tap.is_int(walker.x, 0, String.Format("%s: destination x", "Character.AddWaypoint"));
  tap.is_int(walker.y, 0, String.Format("%s: destination y", "Character.AddWaypoint"));
}

//-----------------------------------------------------------------------------
// MAIN
//-----------------------------------------------------------------------------

void TestCharacters()
{
  tap.Comment("start Character tests");
  int old_game_speed = GetGameSpeed();
  SetGameSpeed(1000);
  
  // Disable characters and objects, avoid interfering with our tests
  TestHelpers.HideRoomObjects();
  
  Game.Camera.SetAt(0, 0);
  cWalker1.ChangeRoom(player.Room);
  
  TestCharacterProperties(cWalker1);
  
  cWalker1.x = 100;
  cWalker1.y = 100;
  cWalker1.on = true;
  cWalker1.Transparency = 0;
  cWalker1.ManualScaling = true;
  cWalker1.Scaling = 100;
  
  TestGraphicPosition();
  TestViewRender();
  
  cWalker1.on = true;
  cWalker2.on = true;
  
  TestChangingDirectionLoop();
  TestTurnOnSpotInstant();
  TestFaceLocation();
  TestTurnOnSpotAnimating();
  TestAnimate();
  TestIdleViewStart();
  TestIdleViewInterrupt();
  TestIdleViewLoop();
  TestSimpleMovement(cWalker1);
  
  SetGameSpeed(old_game_speed);
  tap.Comment("end Character tests");
}
