// Test Characters Module Script
int GetTestCharacterMoveCount()
{
  return 0
  + 12 * 3 // direct move
  + 7      // waypoints move
  + 126    // move by segments
  ;
}

//-----------------------------------------------------------------------------
// TEST MOVING AND WALKING
//-----------------------------------------------------------------------------

void TestMoveDirect(Character* walker, String test_name, int sx, int sy, int dx, int dy, bool use_walk, BlockingStyle style)
{
  walker.x = sx;
  walker.y = sy;
  if (use_walk)
  {
    walker.Walk(dx, dy, style, eAnywhere);
  }
  else
  {
    walker.Move(dx, dy, style, eAnywhere);
  }
  if (style == eNoBlock)
  {
    while (walker.Moving) Wait(1);
  }
  tap.ok(!walker.Moving, String.Format("%s: finished move", test_name));
  tap.is_int(walker.x, dx, String.Format("%s: destination x", test_name));
  tap.is_int(walker.y, dy, String.Format("%s: destination y", test_name));
}

void TestMoveDirectToWaypoint(Character* walker, String test_name, int p_start, int p_end, int t_const, bool x_axis)
{
  int p_range1, p_range2;
  if (p_start <= p_end)
  {
    p_range1 = p_start;
    p_range2 = p_end;
  }
  else
  {
    p_range1 = p_end;
    p_range2 = p_start;
  }
  
  bool p_coords_in_range = true;
  bool t_coords_const = true;
  while (walker.Moving && (x_axis && walker.x != p_end) || (!x_axis && walker.y != p_end))
  {
    if (x_axis)
    {
      if (!(walker.x >= p_range1 && walker.x <= p_range2))
      {
        p_coords_in_range = false;
      }
      if (walker.x != p_end && walker.y != t_const)
      {
        t_coords_const = false;
      }
    }
    else
    {
      if (!(walker.y >= p_range1 && walker.y <= p_range2))
      {
        p_coords_in_range = false;
      }
      if (walker.y != p_end && walker.x != t_const)
      {
        t_coords_const = false;
      }
    }
    
    Wait(1);
  }
  tap.ok(p_coords_in_range && t_coords_const, String.Format("%s: move position stayed in range", test_name));
  // NOTE: we cannot test exact coords here, because character may already be turned and start moving towards next waypoint
}

// Tests moving and walking WITHOUT pathfinding (eAnywhere), 
// only for the sake of testing the fact of movement itself.
void TestSimpleMovement(Character* walker)
{
  // Move
  TestMoveDirect(walker, "Character.Move eBlock Hor", 0, 0, 100, 0, false, eBlock);
  TestMoveDirect(walker, "Character.Move eBlock Ver", 0, 0, 0, 100, false, eBlock);
  TestMoveDirect(walker, "Character.Move eBlock Diag", 0, 0, 100, 100, false, eBlock);
  TestMoveDirect(walker, "Character.Move eNoBlock Hor", 0, 0, 100, 0, false, eNoBlock);
  TestMoveDirect(walker, "Character.Move eNoBlock Ver", 0, 0, 0, 100, false, eNoBlock);
  TestMoveDirect(walker, "Character.Move eNoBlock Diag", 0, 0, 100, 100, false, eNoBlock);
  // Walk
  TestMoveDirect(walker, "Character.Walk eBlock Hor", 0, 0, 100, 0, true, eBlock);
  TestMoveDirect(walker, "Character.Walk eBlock Ver", 0, 0, 0, 100, true, eBlock);
  TestMoveDirect(walker, "Character.Walk eBlock Diag", 0, 0, 100, 100, true, eBlock);
  TestMoveDirect(walker, "Character.Walk eNoBlock Hor", 0, 0, 100, 0, true, eNoBlock);
  TestMoveDirect(walker, "Character.Walk eNoBlock Ver", 0, 0, 0, 100, true, eNoBlock);
  TestMoveDirect(walker, "Character.Walk eNoBlock Diag", 0, 0, 100, 100, true, eNoBlock);
  
  // AddWaypoint
  walker.x = 0;
  walker.y = 0;
  walker.AddWaypoint(100, 0);
  walker.AddWaypoint(100, 100);
  walker.AddWaypoint(0, 100);
  walker.AddWaypoint(0, 0);
  TestMoveDirectToWaypoint(walker, "Character.AddWaypoint 0,0->1,0", 0, 100, 0, true);
  TestMoveDirectToWaypoint(walker, "Character.AddWaypoint 1,0->1,1", 0, 100, 100, false);
  TestMoveDirectToWaypoint(walker, "Character.AddWaypoint 1,1->0,1", 100, 0, 100, true);
  TestMoveDirectToWaypoint(walker, "Character.AddWaypoint 0,1->0,0", 100, 0, 0, false);
  tap.ok(!walker.Moving, String.Format("%s: finished move", "Character.AddWaypoint"));
  tap.is_int(walker.x, 0, String.Format("%s: destination x", "Character.AddWaypoint"));
  tap.is_int(walker.y, 0, String.Format("%s: destination y", "Character.AddWaypoint"));
}

void TestMoveProgress_OverSegment2(Character* walker, int walkx[], int walky[], int from_step, int steps_n, String test_name)
{
  // NOTE: in AGS 3.x the walking progress is always 1 step ahead of character position.
  // First update actually sets character to the starting position, and increments progress, 
  // which will be applied only after the next update, and so forth.
  // Therefore there has to be +1 update to reach the end of the segment (and possibly the
  // beginning of the next segment).
  int end = from_step + steps_n;
  if (end >= walkx.Length)
     end = walkx.Length;
  for (int i = from_step; i < end; i++)
  {
    Wait(1);
    tap.is_int(walker.x, walkx[i], String.Format(String.Format("%s: step %d x", test_name, i)));
    tap.is_int(walker.y, walky[i], String.Format(String.Format("%s: step %d y", test_name, i)));
  }
}

void TestMoveProgress_OverSegment(Character* walker, int walkx[], int walky[], String test_name)
{
  TestMoveProgress_OverSegment2(walker, walkx, walky, 0, walkx.Length, test_name);
}

int[] MakeWalkXSteps(int fromx, int destx, int speedx, bool stop_at_end)
{
  int dist, dx;
  if (fromx <= destx)
  {
    dist = destx - fromx;
    dx = speedx;
  }
  else
  {
    dist = fromx - destx;
    dx = -speedx;
  }
  int steps_n = dist / speedx;
  if (stop_at_end && (dist % speedx))
    steps_n++;
  int walkx[] = new int[steps_n];
  for (int i = 0; i < steps_n; i++)
    walkx[i] = fromx + dx * i;
  return walkx;
}

int[] MakeWalkXFixed(int fixedx, int steps_n)
{
  int walkx[] = new int[steps_n];
  for (int i = 0; i < steps_n; i++)
    walkx[i] = fixedx;
  return walkx;
}

void TestMoveProgress_OverSegment_AutoCalc(Character* walker, int fromx, int fromy, int destx, int desty,
  int speedx, int speedy, String test_name)
{
  int walkx[], walky[];
  if (fromx != destx)
    walkx = MakeWalkXSteps(fromx, destx, speedx, true);
  if (fromy != desty)
    walky = MakeWalkXSteps(fromy, desty, speedy, true);
  if (walkx == null && walky != null)
    walkx = MakeWalkXFixed(fromx, walky.Length);
  else if (walky == null && walkx != null)
    walky = MakeWalkXFixed(fromy, walkx.Length);
  else
    return;
  
  TestMoveProgress_OverSegment(walker, walkx, walky, test_name);
}

void TestMoveProgress(Character* walker, int fromx, int fromy, int destx, int desty, int speedx, int speedy, String test_name)
{
  walker.SetWalkSpeed(speedx, speedy);
  walker.x = fromx;
  walker.y = fromy;
  walker.Move(destx, desty, eNoBlock, eAnywhere);
  tap.ok(walker.Moving, String.Format("%s: is moving", test_name));
  tap.is_int(walker.x, fromx, String.Format("%s: start position x", test_name));
  tap.is_int(walker.y, fromy, String.Format("%s: start position y", test_name));
  
  TestMoveProgress_OverSegment_AutoCalc(walker, fromx, fromy, destx, desty, speedx, speedy, test_name);

  Wait(1); // final step update
  tap.ok(!walker.Moving, String.Format("%s: done moving", test_name));
  tap.is_int(walker.x, destx, String.Format("%s: end position x", test_name));
  tap.is_int(walker.y, desty, String.Format("%s: end position y", test_name));
}

// Character walks along the rectangular-shaped looped path
void TestMoveProgressMultiSegment(Character* walker)
{
  String test_name = "Character.Move progress multi-seg";
  
  int speedx = 4;
  int speedy = 2;
  walker.SetWalkSpeed(speedx, speedy);
  walker.x = 100;
  walker.y = 100;
  walker.Move(116, 100, eNoBlock, eAnywhere);
  walker.AddWaypoint(116, 108);
  walker.AddWaypoint(100, 108);
  walker.AddWaypoint(100, 100);
  tap.ok(walker.Moving, String.Format("%s: is moving", test_name));
  tap.is_int(walker.x, 100, String.Format("%s: start position x", test_name));
  tap.is_int(walker.y, 100, String.Format("%s: start position y", test_name));
  
  TestMoveProgress_OverSegment_AutoCalc(walker, 100, 100, 116, 100, speedx, speedy, String.Format("%s (seg1)", test_name));
  Wait(1); // final seg step update
  TestMoveProgress_OverSegment_AutoCalc(walker, 116, 100, 116, 108, speedx, speedy, String.Format("%s (seg2)", test_name));
  Wait(1); // final seg step update
  TestMoveProgress_OverSegment_AutoCalc(walker, 116, 108, 100, 108, speedx, speedy, String.Format("%s (seg3)", test_name));
  Wait(1); // final seg step update
  TestMoveProgress_OverSegment_AutoCalc(walker, 100, 108, 100, 100, speedx, speedy, String.Format("%s (seg4)", test_name));
  
  Wait(1); // final step update
  tap.ok(!walker.Moving, String.Format("%s: done moving", test_name));
  tap.is_int(walker.x, 100, String.Format("%s: end position x", test_name));
  tap.is_int(walker.y, 100, String.Format("%s: end position y", test_name));
}

// Character walks along the straight path consisting of multiple very short segments, 
// each shorter than character's walk speed
void TestMoveProgressMultiSegmentShort(Character* walker)
{
  String test_name = "Character.Move progress multi-shorts";
  
  int speedx = 4;
  int speedy = 4;
  walker.SetWalkSpeed(speedx, speedy);
  walker.x = 100;
  walker.y = 100;
  walker.Move(102, 100, eNoBlock, eAnywhere);
  walker.AddWaypoint(104, 100);
  walker.AddWaypoint(106, 100);
  walker.AddWaypoint(108, 100);
  walker.AddWaypoint(110, 100);
  walker.AddWaypoint(112, 100);
  walker.AddWaypoint(114, 100);
  walker.AddWaypoint(116, 100);
  walker.AddWaypoint(118, 100);
  walker.AddWaypoint(118, 102);
  walker.AddWaypoint(118, 104);
  walker.AddWaypoint(118, 106);
  walker.AddWaypoint(118, 108);
  tap.ok(walker.Moving, String.Format("%s: is moving", test_name));
  tap.is_int(walker.x, 100, String.Format("%s: start position x", test_name));
  tap.is_int(walker.y, 100, String.Format("%s: start position y", test_name));
  
  int total_steps = 13;
  int walkx[] = new int[total_steps];
  int walky[] = new int[total_steps];
  for (int i = 0; i < 9; i++)
  {
    walkx[i] = 100 + i * 2;
    walky[i] = 100;
  }
  for (int i = 9; i < 13; i++)
  {
    walkx[i] = 118;
    walky[i] = 100 + (i-9) * 2;
  }
  
  for (int i = 0; i < total_steps; i++)
  {
    TestMoveProgress_OverSegment2(walker, walkx, walky, i, 1, String.Format("%s (seg%d)", test_name, i+1));
    Wait(1); // final seg step update
  }
  
  tap.ok(!walker.Moving, String.Format("%s: done moving", test_name));
  tap.is_int(walker.x, 118, String.Format("%s: end position x", test_name));
  tap.is_int(walker.y, 108, String.Format("%s: end position y", test_name));
}

// Tests how movement progresses step by step
void TestMovementProgress(Character* walker)
{
  walker.MovementLinkedToAnimation = false;

  TestMoveProgress(walker, 100, 100, 116, 100, 4, 2, "Character.Move progress (hor line pos)");
  TestMoveProgress(walker, 100, 100, 100, 108, 4, 2, "Character.Move progress (ver line pos)");
  TestMoveProgress(walker, 116, 100, 100, 100, 4, 2, "Character.Move progress (hor line neg)");
  TestMoveProgress(walker, 100, 108, 100, 100, 4, 2, "Character.Move progress (ver line neg)");
  
  TestMoveProgressMultiSegment(walker);
  TestMoveProgressMultiSegmentShort(walker);
}

//-----------------------------------------------------------------------------
// MAIN
//-----------------------------------------------------------------------------

void TestCharacterMove()
{
  tap.Comment("start Character Move tests");
  int old_game_speed = GetGameSpeed();
  SetGameSpeed(1000);
  
  TestSimpleMovement(cWalker1);
  TestMovementProgress(cWalker1);
  
  SetGameSpeed(old_game_speed);
  tap.Comment("end Character Move tests");
}
