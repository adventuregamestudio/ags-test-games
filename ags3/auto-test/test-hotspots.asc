// Test Hotspots Module Script
int GetTestHotspotsCount()
{
  return 0
  + 9 // getatscreenxy
  ;
}

void TestHotspots()
{
  tap.Comment("start Hotspots tests");
  
  hotspot[1].Enabled = true;
  Hotspot* testH;
  testH = Hotspot.GetAtRoomXY(5, 5);
  tap.ok(testH == hotspot[0], "Hotspot.GetAtRoomXY: hit-test empty place");
  testH = Hotspot.GetAtRoomXY(270, 28);
  tap.ok(testH == hotspot[1], "Hotspot.GetAtRoomXY: hit-test hotspot");
  hotspot[1].Enabled = false;
  testH = Hotspot.GetAtRoomXY(270, 28);
  tap.ok(testH == hotspot[0], "Hotspot.GetAtRoomXY: can't hit disabled hotspot");
  testH = Hotspot.GetAtRoomXY(270, 28, eHit_Any);
  tap.ok(testH == hotspot[1], "Hotspot.GetAtRoomXY: hit disabled hotspot in in eHit_Any mode");
  hotspot[1].Enabled = true;
  
  testH = Hotspot.GetAtScreenXY(5, 5);
  tap.ok(testH == hotspot[0], "Hotspot.GetAtScreenXY: hit-test empty place");
  testH = Hotspot.GetAtScreenXY(270, 28);
  tap.ok(testH == hotspot[1], "Hotspot.GetAtScreenXY: hit-test hotspot (screen pos match room pos)");
  hotspot[1].Enabled = false;
  testH = Hotspot.GetAtScreenXY(270, 28);
  tap.ok(testH == hotspot[0], "Hotspot.GetAtScreenXY: can't hit disabled hotspot");
  testH = Hotspot.GetAtScreenXY(270, 28, eHit_Any);
  tap.ok(testH == hotspot[1], "Hotspot.GetAtScreenXY: hit disabled hotspot in in eHit_Any mode");
  hotspot[1].Enabled = true;
  
  // Test "scrolling" room
  Game.Camera.SetSize(80, 80);
  Game.Camera.SetAt(320 - 80, 0);
  Screen.Viewport.SetPosition(0, 0, 80, 80);
  testH = Hotspot.GetAtScreenXY(270 - (320 - 80), 28);
  tap.ok(testH == hotspot[1], "Hotspot.GetAtScreenXY: hit-test hotspot (camera offset)");
  
  // CLEANUP
  Game.Camera.SetSize(Room.Width, Room.Height);
  Screen.Viewport.SetPosition(0, 0, Screen.Width, Screen.Height);
  
  tap.Comment("end Hotspots tests");
}
