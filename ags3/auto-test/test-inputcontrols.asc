// Test Input Controls Module Script
int GetTestInputControlsCount()
{
  return 0
    + 9 * 2 // key press
    + 3     // mouse click
    ;
}

String TestName;
int RequestKey;
int RequestMod;
MouseButton RequestButton;

void TestKey_Run(int key, int mod, int combo_key, String test_name)
{
  TestName = test_name;
  RequestKey = key;
  RequestMod = mod;
  RequestButton = 0;
  LastKey = 0;
  LastMod = 0;
  LastMouseButton = 0;
  if (combo_key == 0)
    Game.SimulateKeyPress(key, mod);
  else
    Game.SimulateKeyPress(combo_key, mod);
}

void TestMouseButton_Run(MouseButton button, String test_name)
{
  TestName = test_name;
  RequestKey = 0;
  RequestMod = 0;
  RequestButton = button;
  LastKey = 0;
  LastMod = 0;
  LastMouseButton = 0;
  Mouse.Click(button);
}

void Test_Check()
{
  if (RequestKey > 0)
  {
    tap.is_int(LastKey, RequestKey, String.Format("%s: KeyCode", TestName));
    // NOTE: we cannot test equality in mods, because something else may be on, like NumLock
    tap.ok((LastMod & RequestMod) == RequestMod, String.Format("%s: KeyMod", TestName));
  }
  else if (RequestButton > 0)
  {
    tap.is_int(LastMouseButton, RequestButton, String.Format("%s MouseButton", TestName));
  }
}

int TestInputControls(int counter)
{
  if (counter == 0)
  {
    tap.Comment("start InputControls tests");
  }
  
  // Each case has 3 counter increments: test run + wait + results check
  // we need to make 1 extra wait in between, because the key press event will be handled
  // only during NEXT game frame and AFTER the next repexec.
  bool is_run_case = ((counter % 3) == 0);
  bool is_check_case = ((counter % 3) == 2);
  if (is_run_case)
  {
    int test_index = counter / 3;
    switch (test_index)
    {
    case 0: TestKey_Run(eKeyA, 0, 0, "Game.SimulateKeyPress: basic key A"); break;
    case 1: TestKey_Run(eKeyZ, 0, 0, "Game.SimulateKeyPress: basic key Z"); break;
    case 2: TestKey_Run(eKeyShiftLeft, 0, 0, "Game.SimulateKeyPress: Shift key"); break;
    case 3: TestKey_Run(eKeyCtrlLeft, 0, 0, "Game.SimulateKeyPress: Control key"); break;
    case 4: TestKey_Run(eKeyAltLeft, 0, 0, "Game.SimulateKeyPress: Alt key"); break;
    case 5: TestKey_Run(eKeyA, eKeyModCtrl, eKeyCtrlA, "Game.SimulateKeyPress: old-style combo-key"); break;
    case 6: TestKey_Run(eKeyA, eKeyModShiftLeft, 0, "Game.SimulateKeyPress: new-style key + Shift"); break;
    case 7: TestKey_Run(eKeyA, eKeyModCtrlLeft, 0, "Game.SimulateKeyPress: new-style key + Ctrl"); break;
    case 8: TestKey_Run(eKeyA, eKeyModAltLeft, 0, "Game.SimulateKeyPress: new-style key + Alt"); break;
    case 9: TestMouseButton_Run(eMouseLeft, "Mouse.Click: LMB"); break;
    case 10: TestMouseButton_Run(eMouseRight, "Mouse.Click: RMB"); break;
    case 11: TestMouseButton_Run(eMouseMiddle, "Mouse.Click: MMB"); break;
    }
  }
  else if (is_check_case)
  {
    Test_Check();
  }
  
  counter++;
  if (counter < 12 * 3)
  {
    return counter;
  }
  else
  {
    tap.Comment("end InputControls tests");
    return -1;
  }
}

