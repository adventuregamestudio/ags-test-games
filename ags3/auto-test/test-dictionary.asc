// Test Dictionary Module Script
int GetTestDictionaryCount()
{
  return 46
  + 5 * 4 // contains
  + 5 * 4 // contains unicode
  ;
}

void TestDictionaryContains(Dictionary* dict, bool sorted, bool casesensitive, String test_name)
{
  dict.Clear();
  dict.Set("Key1", "value1");
  dict.Set("key2", "value2");
  
  tap.ok(dict.Contains("Key1"), String.Format("%s: Contains matches exact key (ok 1)", test_name));
  tap.ok(dict.Contains("key2"), String.Format("%s: Contains matches exact key (ok 2)", test_name));
  tap.nok(dict.Contains("Yey1"), String.Format("%s: Contains fails at wrong key", test_name));
  if (casesensitive)
  {
    tap.nok(dict.Contains("kEy1"), String.Format("%s: Contains should be case-sensitive (nok 1)", test_name));
    tap.nok(dict.Contains("KeY2"), String.Format("%s: Contains should be case-sensitive (nok 2)", test_name));
  }
  else
  {
    tap.ok(dict.Contains("kEy1"), String.Format("%s: Contains should be case-insensitive (ok 1)", test_name));
    tap.ok(dict.Contains("KeY2"), String.Format("%s: Contains should be case-insensitive (ok 2)", test_name));
  }
}

void TestDictionaryContainsUnicode(Dictionary* dict, bool sorted, bool casesensitive, String test_name)
{
  dict.Clear();
  dict.Set("FUßGÄNGERÜBERGÄNGE_1", "value1");
  dict.Set("fußgängerübergänge_2", "value2");
  
  tap.ok(dict.Contains("FUßGÄNGERÜBERGÄNGE_1"), String.Format("%s: Contains matches exact key (ok 1)", test_name));
  tap.ok(dict.Contains("fußgängerübergänge_2"), String.Format("%s: Contains matches exact key (ok 2)", test_name));
  tap.nok(dict.Contains("FUßGÄNGERÄBERGÄNGE_1"), String.Format("%s: Contains fails at wrong key", test_name));
  if (casesensitive)
  {
    tap.nok(dict.Contains("FUßgäNGERüberGÄNGE_1"), String.Format("%s: Contains should be case-sensitive (nok 1)", test_name));
    tap.nok(dict.Contains("fußGÄngerÜBERgänge_2"), String.Format("%s: Contains should be case-sensitive (nok 2)", test_name));
  }
  else
  {
    tap.ok(dict.Contains("FUßgäNGERüberGÄNGE_1"), String.Format("%s: Contains should be case-insensitive (ok 1)", test_name));
    tap.ok(dict.Contains("fußGÄngerÜBERgänge_2"), String.Format("%s: Contains should be case-insensitive (ok 2)", test_name));
  }
}

void TestDictionary()
{  
  tap.Comment("start Dictionary tests");
  
  // Create a dictionary, add items, and check if Contains works
  {
    Dictionary* myDictionary = Dictionary.Create();
    myDictionary.Set("my-key1", "my-value1");

    tap.ok(myDictionary.Contains("my-key1"), "Contains should return true for added key");
    tap.ok(!myDictionary.Contains("non-existent-key"), "Contains should return false for non-existent key");
  }

  // Get and Set values in dictionary
  {
    Dictionary* myDictionary = Dictionary.Create();
    myDictionary.Set("a-key", "a-value");

    tap.is(myDictionary.Get("a-key"), "a-value", "Get should return the correct value");
    tap.is(myDictionary.Get("non-existent-key"), null, "Get should return null for non-existent key");

    myDictionary.Set("a-key", "new-value");
    tap.is(myDictionary.Get("a-key"), "new-value", "Set should update the value for an existing key");
  }

  // Remove key and check if it exists
  {
    Dictionary* myDictionary = Dictionary.Create();
    myDictionary.Set("key-to-remove", "value");

    tap.ok(myDictionary.Contains("key-to-remove"), "Contains should return true before removal");

    myDictionary.Remove("key-to-remove");
    tap.ok(!myDictionary.Contains("key-to-remove"), "Contains should return false after removal");
  }

  // GetKeysAsArray and GetItemsAsArray
  {
    Dictionary* myDictionary = Dictionary.Create(eSorted, eCaseSensitive);
    myDictionary.Clear();
    myDictionary.Set("Z", "Z value");
    myDictionary.Set("a", "a value");
    myDictionary.Set("A", "A value");
    myDictionary.Set("z", "z value");
    
    String keys[] = myDictionary.GetKeysAsArray();
    String items[] = myDictionary.GetValuesAsArray();
    tap.is_int(keys.Length, 4, "Dictionary.GetKeysAsArray: ascii, has correct key count");
    tap.is_int(items.Length, 4, "Dictionary.GetValuesAsArray: ascii, has correct item count");
    tap.is(keys[0], "A", "Dictionary.GetKeysAsArray: ascii, item order (0)");
    tap.is(keys[1], "Z", "Dictionary.GetKeysAsArray: ascii, item order (1)");
    tap.is(keys[2], "a", "Dictionary.GetKeysAsArray: ascii, item order (2)");
    tap.is(keys[3], "z", "Dictionary.GetKeysAsArray: ascii, item order (3)");
    tap.is(items[0], "A value", "Dictionary.GetValuesAsArray: ascii, item order (0)");
    tap.is(items[1], "Z value", "Dictionary.GetValuesAsArray: ascii, item order (1)");
    tap.is(items[2], "a value", "Dictionary.GetValuesAsArray: ascii, item order (2)");
    tap.is(items[3], "z value", "Dictionary.GetValuesAsArray: ascii, item order (3)");
  }
  
  // GetItemsAsArray UTF-8
  {
    Dictionary* myDictionary = Dictionary.Create(eSorted, eCaseSensitive);
    myDictionary.Clear();
    myDictionary.Set("Z", "Z value");
    myDictionary.Set("a", "a value");
    myDictionary.Set("Ä", "Ä value");
    myDictionary.Set("A", "A value");
    myDictionary.Set("ä", "ä value");
    myDictionary.Set("z", "z value");
    
    String keys[] = myDictionary.GetKeysAsArray();
    String items[] = myDictionary.GetValuesAsArray();
    tap.is_int(keys.Length, 6, "Dictionary.GetKeysAsArray: UTF-8, has correct key count");
    tap.is_int(items.Length, 6, "Dictionary.GetValuesAsArray: UTF-8, has correct item count");
    tap.is(keys[0], "A", "Dictionary.GetKeysAsArray: UTF-8, item order (0)");
    tap.is(keys[1], "Z", "Dictionary.GetKeysAsArray: UTF-8, item order (1)");
    tap.is(keys[2], "a", "Dictionary.GetKeysAsArray: UTF-8, item order (2)");
    tap.is(keys[3], "z", "Dictionary.GetKeysAsArray: UTF-8, item order (3)");
    tap.is(keys[4], "Ä", "Dictionary.GetKeysAsArray: UTF-8, item order (4)");
    tap.is(keys[5], "ä", "Dictionary.GetKeysAsArray: UTF-8, item order (5)");
    tap.is(items[0], "A value", "Dictionary.GetValuesAsArray: UTF-8, item order (0)");
    tap.is(items[1], "Z value", "Dictionary.GetValuesAsArray: UTF-8, item order (1)");
    tap.is(items[2], "a value", "Dictionary.GetValuesAsArray: UTF-8, item order (2)");
    tap.is(items[3], "z value", "Dictionary.GetValuesAsArray: UTF-8, item order (3)");
    tap.is(items[4], "Ä value", "Dictionary.GetValuesAsArray: UTF-8, item order (4)");
    tap.is(items[5], "ä value", "Dictionary.GetValuesAsArray: UTF-8, item order (5)");
  }
  
  // GetItemsAsArray UTF-8, Locale-aware (based on en_US locale)
  {
    Dictionary* myDictionary = Dictionary.Create(eSorted, eCaseSensitiveLocaleAware);
    myDictionary.Clear();
    myDictionary.Set("Z", "Z value");
    myDictionary.Set("a", "a value");
    myDictionary.Set("Ä", "Ä value");
    myDictionary.Set("A", "A value");
    myDictionary.Set("ä", "ä value");
    myDictionary.Set("z", "z value");
    
    String keys[] = myDictionary.GetKeysAsArray();
    String items[] = myDictionary.GetValuesAsArray();
    tap.is_int(keys.Length, 6, "Dictionary.GetKeysAsArray: UTF-8, has correct key count");
    tap.is_int(items.Length, 6, "Dictionary.GetValuesAsArray: UTF-8, has correct item count");
    tap.is(keys[0], "a", "Dictionary.GetKeysAsArray: UTF-8 locale aware, item order (0)");
    tap.is(keys[1], "A", "Dictionary.GetKeysAsArray: UTF-8 locale aware, item order (1)");
    tap.is(keys[2], "ä", "Dictionary.GetKeysAsArray: UTF-8 locale aware, item order (2)");
    tap.is(keys[3], "Ä", "Dictionary.GetKeysAsArray: UTF-8 locale aware, item order (3)");
    tap.is(keys[4], "z", "Dictionary.GetKeysAsArray: UTF-8 locale aware, item order (4)");
    tap.is(keys[5], "Z", "Dictionary.GetKeysAsArray: UTF-8 locale aware, item order (5)");
    tap.is(items[0], "a value", "Dictionary.GetValuesAsArray: UTF-8 locale aware, item order (0)");
    tap.is(items[1], "A value", "Dictionary.GetValuesAsArray: UTF-8 locale aware, item order (1)");
    tap.is(items[2], "ä value", "Dictionary.GetValuesAsArray: UTF-8 locale aware, item order (2)");
    tap.is(items[3], "Ä value", "Dictionary.GetValuesAsArray: UTF-8 locale aware, item order (3)");
    tap.is(items[4], "z value", "Dictionary.GetValuesAsArray: UTF-8 locale aware, item order (4)");
    tap.is(items[5], "Z value", "Dictionary.GetValuesAsArray: UTF-8 locale aware, item order (5)");
  }

  // Clear the dictionary
  {
    Dictionary* myDictionary = Dictionary.Create();
    myDictionary.Set("key1", "value1");
    myDictionary.Set("key2", "value2");

    myDictionary.Clear();
    tap.ok(myDictionary.ItemCount == 0, "Clear should remove all items from the dictionary");
  }

  // Contains with different SortStyles and CompareStyles
  {
    Dictionary* sortedCaseSensitiveDict = Dictionary.Create(eSorted, eCaseSensitive);
    TestDictionaryContains(sortedCaseSensitiveDict, true, true, "Dictionary (sorted, case)");
    Dictionary* sortedCaseInsensitiveDict = Dictionary.Create(eSorted, eCaseInsensitive);
    TestDictionaryContains(sortedCaseInsensitiveDict, true, false, "Dictionary (sorted, nocase)");
    Dictionary* unsortedCaseSensitiveDict = Dictionary.Create(eNonSorted, eCaseSensitive);
    TestDictionaryContains(unsortedCaseSensitiveDict, false, true, "Dictionary (unsorted, case)");
    Dictionary* unsortedCaseInsensitiveDict = Dictionary.Create(eNonSorted, eCaseInsensitive);
    TestDictionaryContains(unsortedCaseInsensitiveDict, false, false, "Dictionary (unsorted, nocase)");
  }
  
  // Contains with different SortStyles and CompareStyles, Unicode strings
  {
    Dictionary* sortedCaseSensitiveDict = Dictionary.Create(eSorted, eCaseSensitive);
    TestDictionaryContainsUnicode(sortedCaseSensitiveDict, true, true, "Dictionary (unicode, sorted, case)");
    Dictionary* sortedCaseInsensitiveDict = Dictionary.Create(eSorted, eCaseInsensitive);
    TestDictionaryContainsUnicode(sortedCaseInsensitiveDict, true, false, "Dictionary (unicode, sorted, nocase)");
    Dictionary* unsortedCaseSensitiveDict = Dictionary.Create(eNonSorted, eCaseSensitive);
    TestDictionaryContainsUnicode(unsortedCaseSensitiveDict, false, true, "Dictionary (unicode, unsorted, case)");
    Dictionary* unsortedCaseInsensitiveDict = Dictionary.Create(eNonSorted, eCaseInsensitive);
    TestDictionaryContainsUnicode(unsortedCaseInsensitiveDict, false, false, "Dictionary (unicode, unsorted, nocase)");
  }

  tap.Comment("end Dictionary tests");
}
