// Test File Directory Module Script
int GetTestFileDirectoryCount()
{
  return 11;
}

void TestFileDirectory()
{
  tap.Comment("start File Directory tests");
  
  // NOTE: we cannot make assumptions about the build type here, 
  // so keep testing for the files that must be present in the game's dir
  ListBox1.FillDirList("*.*");
  bool found_file_ags, found_file_cfg;
  tap.ok(ListBox1.ItemCount > 0, "FillDirList: minimal required file count found");
  for (int i = 0; i < ListBox1.ItemCount; i++)
  {
    if (ListBox1.Items[i] == Game.FileName)
      found_file_ags = true;
    else if (ListBox1.Items[i] == "acsetup.cfg")
      found_file_cfg = true;
  }
  tap.ok(found_file_ags, "FillDirList: game file is found");
  tap.ok(found_file_cfg, "FillDirList: config file is found");
  
  ListBox1.FillDirList("$DATA$/CustomData/*.txt");
  tap.is_int(ListBox1.ItemCount, 3, "FillDirList: custom data file count");
  tap.is(ListBox1.SafeGetItemAt(0), "CustomData/file1.txt", "FillDirList: custom file1.txt index");
  tap.is(ListBox1.SafeGetItemAt(1), "CustomData/file2.txt", "FillDirList: custom file2.txt index");
  tap.is(ListBox1.SafeGetItemAt(2), "CustomData/file3.txt", "FillDirList: custom file3.txt index");
    
  ListBox1.FillDirList("$DATA$/CustomData/*.txt", eFileSort_Name, eSortDescending);
  tap.is_int(ListBox1.ItemCount, 3, "FillDirList: custom data file count (descending)");
  tap.is(ListBox1.SafeGetItemAt(0), "CustomData/file3.txt", "FillDirList: custom file3.txt index (descending)");
  tap.is(ListBox1.SafeGetItemAt(1), "CustomData/file2.txt", "FillDirList: custom file2.txt index (descending)");
  tap.is(ListBox1.SafeGetItemAt(2), "CustomData/file1.txt", "FillDirList: custom file1.txt index (descending)");
  
  ListBox1.Clear();
  tap.Comment("end File Directory tests");
}
