// Test String Module Script
int GetTestStringCount()
{
  bool can_locale_tests = System.LocaleName != "";
  
  int test_count = 72;
  if (can_locale_tests)
    test_count += 16;
  return test_count;
}

void TestString()
{
  bool can_locale_tests = System.LocaleName != "";
  
  tap.Comment("start String tests");
  // String.Append
  { 
    String mytext = "Hello";
    mytext = mytext.Append("World");
    tap.is(mytext, "HelloWorld", "String.Append test");
    
    // UTF-8 specific test
    String utfText = "Hell";
    utfText = utfText.AppendChar('ä');  // Append a UTF-8 character
    tap.is(utfText, "Hellä", "String.AppendChar UTF-8 test");
  }
  
  // String.AppendChar
  { 
    String mytext = "Hell";
    mytext = mytext.AppendChar('o');
    tap.is(mytext, "Hello", "String.AppendChar test");
  }
  
  // String.CompareTo
  {
    String mytext = "Hello";
    tap.ok(mytext.CompareTo("Hello", eCaseInsensitive) == 0,  "String.CompareTo: identical, case insensitive");
    tap.ok(mytext.CompareTo("Hello", eCaseSensitive) == 0,  "String.CompareTo: identical, case sensitive");
    tap.ok(mytext.CompareTo("hello", eCaseInsensitive) == 0,  "String.CompareTo: case diff, case insensitive");
    tap.ok(mytext.CompareTo("hello", eCaseSensitive) < 0,  "String.CompareTo: case diff, case sensitive");
    
    // UTF-8 specific test
    String utfText = "ÀÁÂÃÄÅÇÈÉÊËÌÍÎÏÐÑÒÓÔÕÖØÙÚÛÜÝÞĀĂĄĆĈĊČĎĐĒĔĖĘĚĜĞĠĢĤĦĨĪÜ";
    tap.ok(utfText.CompareTo("ÀÁÂÃÄÅÇÈÉÊËÌÍÎÏÐÑÒÓÔÕÖØÙÚÛÜÝÞĀĂĄĆĈĊČĎĐĒĔĖĘĚĜĞĠĢĤĦĨĪÜ", eCaseInsensitive) == 0, "String.CompareTo: UTF-8 identical, case insensitive");
    tap.ok(utfText.CompareTo("ÀÁÂÃÄÅÇÈÉÊËÌÍÎÏÐÑÒÓÔÕÖØÙÚÛÜÝÞĀĂĄĆĈĊČĎĐĒĔĖĘĚĜĞĠĢĤĦĨĪÜ", eCaseSensitive) == 0, "String.CompareTo: UTF-8 identical, case sensitive");
    tap.ok(utfText.CompareTo("àáâãäåçèéêëìíîïðñòóôõöøùúûüýþāăąćĉċčďđēĕėęěĝğġģĥħĩīü", eCaseInsensitive) == 0, "String.CompareTo: UTF-8 case diff, case insensitive");
    tap.ok(utfText.CompareTo("àáâãäåçèéêëìíîïðñòóôõöøùúûüýþāăąćĉċčďđēĕėęěĝğġģĥħĩīü", eCaseSensitive) < 0, "String.CompareTo: UTF-8 case diff, case sensitive");
    
    // Alphabetic comparison (based on en_US locale)
    utfText = "À";
    tap.ok(utfText.CompareTo("A", eCaseInsensitive) > 0, "String.CompareTo: UTF-8 alphabetic (À), case insensitive (A, gt)");
    tap.ok(utfText.CompareTo("a", eCaseInsensitive) > 0, "String.CompareTo: UTF-8 alphabetic (À), case insensitive (a, gt)");
    tap.ok(utfText.CompareTo("À", eCaseInsensitive) == 0, "String.CompareTo: UTF-8 alphabetic (À), case insensitive (À, eq)");
    tap.ok(utfText.CompareTo("à", eCaseInsensitive) == 0, "String.CompareTo: UTF-8 alphabetic (À), case insensitive (à, eq)");
    tap.ok(utfText.CompareTo("B", eCaseInsensitive) > 0, "String.CompareTo: UTF-8 alphabetic (À), case insensitive (B, gt)");
    tap.ok(utfText.CompareTo("b", eCaseInsensitive) > 0, "String.CompareTo: UTF-8 alphabetic (À), case insensitive (b, gt)");
    tap.ok(utfText.CompareTo("Ü", eCaseInsensitive) < 0, "String.CompareTo: UTF-8 alphabetic (À), case insensitive (Ü, lt)");
    tap.ok(utfText.CompareTo("ü", eCaseInsensitive) < 0, "String.CompareTo: UTF-8 alphabetic (À), case insensitive (ü, lt)");
    //
    tap.ok(utfText.CompareTo("A", eCaseSensitive) > 0, "String.CompareTo: UTF-8 alphabetic (À), case sensitive (A, gt)");
    tap.ok(utfText.CompareTo("a", eCaseSensitive) > 0, "String.CompareTo: UTF-8 alphabetic (À), case sensitive (a, gt)");
    tap.ok(utfText.CompareTo("À", eCaseSensitive) == 0, "String.CompareTo: UTF-8 alphabetic (À), case sensitive (À, eq)");
    tap.ok(utfText.CompareTo("à", eCaseSensitive) < 0, "String.CompareTo: UTF-8 alphabetic (À), case sensitive (à, lt)");
    tap.ok(utfText.CompareTo("B", eCaseSensitive) > 0, "String.CompareTo: UTF-8 alphabetic (À), case sensitive (B, gt)");
    tap.ok(utfText.CompareTo("b", eCaseSensitive) > 0, "String.CompareTo: UTF-8 alphabetic (À), case sensitive (b, gt)");
    tap.ok(utfText.CompareTo("Ü", eCaseSensitive) < 0, "String.CompareTo: UTF-8 alphabetic (À), case sensitive (Ü, lt)");
    tap.ok(utfText.CompareTo("ü", eCaseSensitive) < 0, "String.CompareTo: UTF-8 alphabetic (À), case sensitive (ü, lt)");

    if (can_locale_tests)
    {
      //
      tap.ok(utfText.CompareTo("A", eCaseInsensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case insensitive (A, gt)");
      tap.ok(utfText.CompareTo("a", eCaseInsensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case insensitive (a, gt)");
      tap.ok(utfText.CompareTo("À", eCaseInsensitiveLocaleAware) == 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case insensitive (À, eq)");
      tap.ok(utfText.CompareTo("à", eCaseInsensitiveLocaleAware) == 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case insensitive (à, eq)");
      tap.ok(utfText.CompareTo("B", eCaseInsensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case insensitive (B, lt)");
      tap.ok(utfText.CompareTo("b", eCaseInsensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case insensitive (b, lt)");
      tap.ok(utfText.CompareTo("Ü", eCaseInsensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case insensitive (Ü, lt)");
      tap.ok(utfText.CompareTo("ü", eCaseInsensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case insensitive (ü, lt)");
      //
      tap.ok(utfText.CompareTo("A", eCaseSensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case sensitive (A, gt)");
      tap.ok(utfText.CompareTo("a", eCaseSensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case sensitive (a, gt)");
      tap.ok(utfText.CompareTo("À", eCaseSensitiveLocaleAware) == 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case sensitive (À, eq)");
      // en_US locale has à < À
      tap.ok(utfText.CompareTo("à", eCaseSensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case sensitive (à, gt)");
      tap.ok(utfText.CompareTo("B", eCaseSensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case sensitive (B, lt)");
      tap.ok(utfText.CompareTo("b", eCaseSensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case sensitive (b, lt)");
      tap.ok(utfText.CompareTo("Ü", eCaseSensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case sensitive (Ü, lt)");
      tap.ok(utfText.CompareTo("ü", eCaseSensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (À), locale aware case sensitive (ü, lt)");
    }
  }
  
  // String.Copy
  {
    String mystring = "This is a test string.";
    String newstring = mystring.Copy();
    tap.is(mystring, newstring, "String.Copy test");
  }
  
  // String.EndsWith
  {
    String myString = "Hello from the script!";
    tap.ok(myString.EndsWith("script!", eCaseInsensitive), "String.EndsWith: identical, case insensitive");
    tap.ok(myString.EndsWith("script!", eCaseSensitive), "String.EndsWith: identical, case sensitive");
    tap.ok(myString.EndsWith("SCRIPT!", eCaseInsensitive), "String.EndsWith: case diff, case insensitive");
    tap.nok(myString.EndsWith("SCRIPT!", eCaseSensitive), "String.EndsWith: case diff, case sensitive");
    
    // UTF-8 specific test
    String utfString = "Grüße von München!";
    tap.ok(utfString.EndsWith("München!", eCaseInsensitive), "String.EndsWith: UTF-8 identical, case insensitive");
    tap.ok(utfString.EndsWith("München!", eCaseSensitive), "String.EndsWith: UTF-8 identical, case sensitive");
    tap.ok(utfString.EndsWith("MÜNCHEN!", eCaseInsensitive), "String.EndsWith: UTF-8 case diff, case insensitive");
    tap.nok(utfString.EndsWith("MÜNCHEN!", eCaseSensitive), "String.EndsWith: UTF-8 case diff, case sensitive");
  }
  
  // String.Format
  {
    int health=10;
    String mystring="test";
    String text = String.Format("%s , %d, %c", mystring, health, 'T');
    tap.is(text, "test , 10, T", "String.Format test");
    // NOTE: %f is locale dependant for comma or dot as separator.
  }
  
  // String.IndexOf
  {
    String haystack = "The haystack had a needle in it somewhere.";
    int result = haystack.IndexOf("a needle");
    tap.is_int(result, 17, "String.IndexOf test");
    
    // UTF-8 specific test
    String utfHaystack = "The haystack had a ĄĆĈĊČĎĐĒĔĖĘĚĜĞĠĢĤĦĨ and a needle in it somewhere..";
    int utfResult = utfHaystack.IndexOf("a needle");
    tap.is_int(utfResult, 43, "String.IndexOf UTF-8 test");
  }
  
  // String.IsNullOrEmpty
  {
    String null_string;
    String empty_string = "";
    String nonempty_string = "with text";
    tap.ok(String.IsNullOrEmpty(null_string), "String.IsNullOrEmpty test null string");
    tap.ok(String.IsNullOrEmpty(empty_string), "String.IsNullOrEmpty test empty string");
    tap.ok(!String.IsNullOrEmpty(nonempty_string), "String.IsNullOrEmpty test non-empty string");
  }
  
  // String.LowerCase
  {
    String mystring = "THIS is a test string";
    String lowercased = mystring.LowerCase();
    tap.is(lowercased, "this is a test string", "String.LowerCase test");
    
    // UTF-8 specific test
    String utfString = "FUßGÄNGERÜBERGÄNGE";
    String utfLowercased = utfString.LowerCase();
    tap.is(utfLowercased, "fußgängerübergänge", "String.LowerCase UTF-8 test");
  }
  
  // String.Replace
  {
    String original = "Hello from the script!";
    String changed = original.Replace("Hello", "goodbye", eCaseInsensitive);
    tap.is(changed, "goodbye from the script!", "String.Replace: identical match, case insensitive");
    changed = original.Replace("Hello", "goodbye", eCaseSensitive);
    tap.is(changed, "goodbye from the script!", "String.Replace: identical match, case sensitive");
    changed = original.Replace("hello", "goodbye", eCaseInsensitive);
    tap.is(changed, "goodbye from the script!", "String.Replace: try match case diff, case insensitive");
    changed = original.Replace("hello", "goodbye", eCaseSensitive);
    tap.is(changed, "Hello from the script!", "String.Replace: try match case diff, case sensitive");
    
    // UTF-8 specific test
    String utfOriginal = "Grüße vom München!";
    String utfChanged = utfOriginal.Replace("München", "Berlin", eCaseInsensitive);
    tap.is(utfChanged, "Grüße vom Berlin!", "String.Replace: UTF-8 identical match, case insensitive");
    utfChanged = utfOriginal.Replace("München", "Berlin", eCaseSensitive);
    tap.is(utfChanged, "Grüße vom Berlin!", "String.Replace: UTF-8 identical match, case sensitive");
    utfChanged = utfOriginal.Replace("MÜNCHEN", "Berlin", eCaseInsensitive);
    tap.is(utfChanged, "Grüße vom Berlin!", "String.Replace: UTF-8 try match case diff, case insensitive");
    utfChanged = utfOriginal.Replace("MÜNCHEN", "Berlin", eCaseSensitive);
    tap.is(utfChanged, "Grüße vom München!", "String.Replace: UTF-8 try match case diff, case sensitive");
  }
  
  // String.ReplaceCharAt
  {
    String mystring = "Hello";
    String changed = mystring.ReplaceCharAt(2, 'm');
    tap.is(changed, "Hemlo", "String.ReplaceCharAt test");
    
    // UTF-8 specific test
    String utfString = "ĄĆĈĊČĎĐĒĔĖĘĚĜĞĠĢĤĦĨ";
    String utfChanged = utfString.ReplaceCharAt(3, 's');  // Replacing 'Ċ' with 's'
    tap.is(utfChanged, "ĄĆĈsČĎĐĒĔĖĘĚĜĞĠĢĤĦĨ", "String.ReplaceCharAt UTF-8 test");
  }
  
  // String.StartsWith
  {    
    String myString = "Hello from the script!";
    tap.ok(myString.StartsWith("Hello", eCaseInsensitive), "String.StartsWith: identical, case insensitive");
    tap.ok(myString.StartsWith("Hello", eCaseSensitive), "String.StartsWith: identical, case sensitive");
    tap.ok(myString.StartsWith("HELLO", eCaseInsensitive), "String.StartsWith: case diff, case insensitive");
    tap.nok(myString.StartsWith("HELLO", eCaseSensitive), "String.StartsWith: case diff, case sensitive");
    
    // UTF-8 specific test
    String utfString = "Grüße von München!";
    tap.ok(utfString.StartsWith("Grüße", eCaseInsensitive), "String.StartsWith: UTF-8 identical, case insensitive");
    tap.ok(utfString.StartsWith("Grüße", eCaseSensitive), "String.StartsWith: UTF-8 identical, case sensitive");
    tap.ok(utfString.StartsWith("GRÜßE", eCaseInsensitive), "String.StartsWith: UTF-8 case diff, case insensitive");
    tap.nok(utfString.StartsWith("GRÜßE", eCaseSensitive), "String.StartsWith: UTF-8 case diff, case sensitive");
  }
  
  // String.Substring
  {
    String mystring = "Hello World!";
    String substring = mystring.Substring(3, 5);
    tap.is(substring, "lo Wo", "String.Substring test");    
  }
  
  // String.Truncate
  {
    String mystring = "Hello World!";
    String truncated = mystring.Truncate(7);
    tap.is(truncated, "Hello W", "String.Truncate test");   
  }
  
  // String.UpperCase
  {
    String mystring = "THIS is a test string";
    String uppercased = mystring.UpperCase();
    tap.is(uppercased, "THIS IS A TEST STRING", "String.UpperCase test");  
    
    // UTF-8 specific test
    String utfString = "fußgängerübergänge";
    String utfUppercased = utfString.UpperCase();
    tap.is(utfUppercased, "FUßGÄNGERÜBERGÄNGE", "String.UpperCase UTF-8 test");
  }
  
  // String.AsFloat
  {
    String text1, text2;
    float number1, number2;
    text1 = "57.362";
    text2 = "Hello";
    number1 = text1.AsFloat;
    number2 = text2.AsFloat;
    tap.is_float(number1, 57.362, 0.0001, "String.AsFloat test with ''57.362''");
    tap.is_float(number2, 0.0, 0.0001, "String.AsFloat test with ''Hello''");
  }
  
  // String.AsInt
  {
    String text1, text2;
    int number1, number2;
    text1 = "53";
    text2 = "Hello";
    number1 = text1.AsInt;
    number2 = text2.AsInt;
    tap.is_int(number1, 53, "String.AsInt test with ''53''");
    tap.is_int(number2, 0, "String.AsInt test with ''Hello''");
  }
  
  // String.Chars
  {
    String text = "This is my string.";
    tap.is(String.Format("%c",text.Chars[3]), "s", "String.Chars test");
  }
  
  // String.Length
  {
    String text = "This is my string.";
    tap.is_int(text.Length, 18, "String.Length test");
  }

  tap.Comment("end String tests");
}