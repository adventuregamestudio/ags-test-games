// Test String Module Script
int GetTestStringCount()
{
  return 88;
}

void TestString()
{  
  tap.Comment("start String tests");
  // String.Append
  { 
    String mytext = "Hello";
    mytext = mytext.Append("World");
    tap.is(mytext, "HelloWorld", "String.Append test");
    
    // UTF-8 specific test
    String utfText = "Hell";
    utfText = utfText.AppendChar('√§');  // Append a UTF-8 character
    tap.is(utfText, "Hell√§", "String.AppendChar UTF-8 test");
  }
  
  // String.AppendChar
  { 
    String mytext = "Hell";
    mytext = mytext.AppendChar('o');
    tap.is(mytext, "Hello", "String.AppendChar test");
  }
  
  // String.CompareTo
  {
    String mytext = "Hello";
    tap.ok(mytext.CompareTo("Hello", eCaseInsensitive) == 0,  "String.CompareTo: identical, case insensitive");
    tap.ok(mytext.CompareTo("Hello", eCaseSensitive) == 0,  "String.CompareTo: identical, case sensitive");
    tap.ok(mytext.CompareTo("hello", eCaseInsensitive) == 0,  "String.CompareTo: case diff, case insensitive");
    tap.ok(mytext.CompareTo("hello", eCaseSensitive) < 0,  "String.CompareTo: case diff, case sensitive");
    
    // UTF-8 specific test
    String utfText = "√Ä√Å√Ç√É√Ñ√Ö√á√à√â√ä√ã√å√ç√é√è√ê√ë√í√ì√î√ï√ñ√ò√ô√ö√õ√ú√ù√ûƒÄƒÇƒÑƒÜƒàƒäƒåƒéƒêƒíƒîƒñƒòƒöƒúƒûƒ†ƒ¢ƒ§ƒ¶ƒ®ƒ™√ú";
    tap.ok(utfText.CompareTo("√Ä√Å√Ç√É√Ñ√Ö√á√à√â√ä√ã√å√ç√é√è√ê√ë√í√ì√î√ï√ñ√ò√ô√ö√õ√ú√ù√ûƒÄƒÇƒÑƒÜƒàƒäƒåƒéƒêƒíƒîƒñƒòƒöƒúƒûƒ†ƒ¢ƒ§ƒ¶ƒ®ƒ™√ú", eCaseInsensitive) == 0, "String.CompareTo: UTF-8 identical, case insensitive");
    tap.ok(utfText.CompareTo("√Ä√Å√Ç√É√Ñ√Ö√á√à√â√ä√ã√å√ç√é√è√ê√ë√í√ì√î√ï√ñ√ò√ô√ö√õ√ú√ù√ûƒÄƒÇƒÑƒÜƒàƒäƒåƒéƒêƒíƒîƒñƒòƒöƒúƒûƒ†ƒ¢ƒ§ƒ¶ƒ®ƒ™√ú", eCaseSensitive) == 0, "String.CompareTo: UTF-8 identical, case sensitive");
    tap.ok(utfText.CompareTo("√†√°√¢√£√§√•√ß√®√©√™√´√¨√≠√Æ√Ø√∞√±√≤√≥√¥√µ√∂√∏√π√∫√ª√º√Ω√æƒÅƒÉƒÖƒáƒâƒãƒçƒèƒëƒìƒïƒóƒôƒõƒùƒüƒ°ƒ£ƒ•ƒßƒ©ƒ´√º", eCaseInsensitive) == 0, "String.CompareTo: UTF-8 case diff, case insensitive");
    tap.ok(utfText.CompareTo("√†√°√¢√£√§√•√ß√®√©√™√´√¨√≠√Æ√Ø√∞√±√≤√≥√¥√µ√∂√∏√π√∫√ª√º√Ω√æƒÅƒÉƒÖƒáƒâƒãƒçƒèƒëƒìƒïƒóƒôƒõƒùƒüƒ°ƒ£ƒ•ƒßƒ©ƒ´√º", eCaseSensitive) < 0, "String.CompareTo: UTF-8 case diff, case sensitive");
    
    // Alphabetic comparison (based on en_US locale)
    utfText = "√Ä";
    tap.ok(utfText.CompareTo("A", eCaseInsensitive) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case insensitive (A, gt)");
    tap.ok(utfText.CompareTo("a", eCaseInsensitive) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case insensitive (a, gt)");
    tap.ok(utfText.CompareTo("√Ä", eCaseInsensitive) == 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case insensitive (√Ä, eq)");
    tap.ok(utfText.CompareTo("√†", eCaseInsensitive) == 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case insensitive (√†, eq)");
    tap.ok(utfText.CompareTo("B", eCaseInsensitive) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case insensitive (B, gt)");
    tap.ok(utfText.CompareTo("b", eCaseInsensitive) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case insensitive (b, gt)");
    tap.ok(utfText.CompareTo("√ú", eCaseInsensitive) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case insensitive (√ú, lt)");
    tap.ok(utfText.CompareTo("√º", eCaseInsensitive) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case insensitive (√º, lt)");
    //
    tap.ok(utfText.CompareTo("A", eCaseSensitive) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case sensitive (A, gt)");
    tap.ok(utfText.CompareTo("a", eCaseSensitive) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case sensitive (a, gt)");
    tap.ok(utfText.CompareTo("√Ä", eCaseSensitive) == 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case sensitive (√Ä, eq)");
    tap.ok(utfText.CompareTo("√†", eCaseSensitive) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case sensitive (√†, lt)");
    tap.ok(utfText.CompareTo("B", eCaseSensitive) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case sensitive (B, gt)");
    tap.ok(utfText.CompareTo("b", eCaseSensitive) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case sensitive (b, gt)");
    tap.ok(utfText.CompareTo("√ú", eCaseSensitive) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case sensitive (√ú, lt)");
    tap.ok(utfText.CompareTo("√º", eCaseSensitive) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), case sensitive (√º, lt)");
    //
    tap.ok(utfText.CompareTo("A", eCaseInsensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case insensitive (A, gt)");
    tap.ok(utfText.CompareTo("a", eCaseInsensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case insensitive (a, gt)");
    tap.ok(utfText.CompareTo("√Ä", eCaseInsensitiveLocaleAware) == 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case insensitive (√Ä, eq)");
    tap.ok(utfText.CompareTo("√†", eCaseInsensitiveLocaleAware) == 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case insensitive (√†, eq)");
    tap.ok(utfText.CompareTo("B", eCaseInsensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case insensitive (B, lt)");
    tap.ok(utfText.CompareTo("b", eCaseInsensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case insensitive (b, lt)");
    tap.ok(utfText.CompareTo("√ú", eCaseInsensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case insensitive (√ú, lt)");
    tap.ok(utfText.CompareTo("√º", eCaseInsensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case insensitive (√º, lt)");
    //
    tap.ok(utfText.CompareTo("A", eCaseSensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case sensitive (A, gt)");
    tap.ok(utfText.CompareTo("a", eCaseSensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case sensitive (a, gt)");
    tap.ok(utfText.CompareTo("√Ä", eCaseSensitiveLocaleAware) == 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case sensitive (√Ä, eq)");
    // en_US locale has √† < √Ä
    tap.ok(utfText.CompareTo("√†", eCaseSensitiveLocaleAware) > 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case sensitive (√†, gt)");
    tap.ok(utfText.CompareTo("B", eCaseSensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case sensitive (B, lt)");
    tap.ok(utfText.CompareTo("b", eCaseSensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case sensitive (b, lt)");
    tap.ok(utfText.CompareTo("√ú", eCaseSensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case sensitive (√ú, lt)");
    tap.ok(utfText.CompareTo("√º", eCaseSensitiveLocaleAware) < 0, "String.CompareTo: UTF-8 alphabetic (√Ä), locale aware case sensitive (√º, lt)");
  }
  
  // String.Copy
  {
    String mystring = "This is a test string.";
    String newstring = mystring.Copy();
    tap.is(mystring, newstring, "String.Copy test");
  }
  
  // String.EndsWith
  {
    String myString = "Hello from the script!";
    tap.ok(myString.EndsWith("script!", eCaseInsensitive), "String.EndsWith: identical, case insensitive");
    tap.ok(myString.EndsWith("script!", eCaseSensitive), "String.EndsWith: identical, case sensitive");
    tap.ok(myString.EndsWith("SCRIPT!", eCaseInsensitive), "String.EndsWith: case diff, case insensitive");
    tap.nok(myString.EndsWith("SCRIPT!", eCaseSensitive), "String.EndsWith: case diff, case sensitive");
    
    // UTF-8 specific test
    String utfString = "Gr√º√üe von M√ºnchen!";
    tap.ok(utfString.EndsWith("M√ºnchen!", eCaseInsensitive), "String.EndsWith: UTF-8 identical, case insensitive");
    tap.ok(utfString.EndsWith("M√ºnchen!", eCaseSensitive), "String.EndsWith: UTF-8 identical, case sensitive");
    tap.ok(utfString.EndsWith("M√úNCHEN!", eCaseInsensitive), "String.EndsWith: UTF-8 case diff, case insensitive");
    tap.nok(utfString.EndsWith("M√úNCHEN!", eCaseSensitive), "String.EndsWith: UTF-8 case diff, case sensitive");
  }
  
  // String.Format
  {
    int health=10;
    String mystring="test";
    String text = String.Format("%s , %d, %c", mystring, health, 'T');
    tap.is(text, "test , 10, T", "String.Format test");
    // NOTE: %f is locale dependant for comma or dot as separator.
  }
  
  // String.IndexOf
  {
    String haystack = "The haystack had a needle in it somewhere.";
    int result = haystack.IndexOf("a needle");
    tap.is_int(result, 17, "String.IndexOf test");
    
    // UTF-8 specific test
    String utfHaystack = "The haystack had a ƒÑƒÜƒàƒäƒåƒéƒêƒíƒîƒñƒòƒöƒúƒûƒ†ƒ¢ƒ§ƒ¶ƒ® and a needle in it somewhere..";
    int utfResult = utfHaystack.IndexOf("a needle");
    tap.is_int(utfResult, 43, "String.IndexOf UTF-8 test");
  }
  
  // String.IsNullOrEmpty
  {
    String null_string;
    String empty_string = "";
    String nonempty_string = "with text";
    tap.ok(String.IsNullOrEmpty(null_string), "String.IsNullOrEmpty test null string");
    tap.ok(String.IsNullOrEmpty(empty_string), "String.IsNullOrEmpty test empty string");
    tap.ok(!String.IsNullOrEmpty(nonempty_string), "String.IsNullOrEmpty test non-empty string");
  }
  
  // String.LowerCase
  {
    String mystring = "THIS is a test string";
    String lowercased = mystring.LowerCase();
    tap.is(lowercased, "this is a test string", "String.LowerCase test");
    
    // UTF-8 specific test
    String utfString = "FU√üG√ÑNGER√úBERG√ÑNGE";
    String utfLowercased = utfString.LowerCase();
    tap.is(utfLowercased, "fu√üg√§nger√ºberg√§nge", "String.LowerCase UTF-8 test");
  }
  
  // String.Replace
  {
    String original = "Hello from the script!";
    String changed = original.Replace("Hello", "goodbye", eCaseInsensitive);
    tap.is(changed, "goodbye from the script!", "String.Replace: identical match, case insensitive");
    changed = original.Replace("Hello", "goodbye", eCaseSensitive);
    tap.is(changed, "goodbye from the script!", "String.Replace: identical match, case sensitive");
    changed = original.Replace("hello", "goodbye", eCaseInsensitive);
    tap.is(changed, "goodbye from the script!", "String.Replace: try match case diff, case insensitive");
    changed = original.Replace("hello", "goodbye", eCaseSensitive);
    tap.is(changed, "Hello from the script!", "String.Replace: try match case diff, case sensitive");
    
    // UTF-8 specific test
    String utfOriginal = "Gr√º√üe vom M√ºnchen!";
    String utfChanged = utfOriginal.Replace("M√ºnchen", "Berlin", eCaseInsensitive);
    tap.is(utfChanged, "Gr√º√üe vom Berlin!", "String.Replace: UTF-8 identical match, case insensitive");
    utfChanged = utfOriginal.Replace("M√ºnchen", "Berlin", eCaseSensitive);
    tap.is(utfChanged, "Gr√º√üe vom Berlin!", "String.Replace: UTF-8 identical match, case sensitive");
    utfChanged = utfOriginal.Replace("M√úNCHEN", "Berlin", eCaseInsensitive);
    tap.is(utfChanged, "Gr√º√üe vom Berlin!", "String.Replace: UTF-8 try match case diff, case insensitive");
    utfChanged = utfOriginal.Replace("M√úNCHEN", "Berlin", eCaseSensitive);
    tap.is(utfChanged, "Gr√º√üe vom M√ºnchen!", "String.Replace: UTF-8 try match case diff, case sensitive");
  }
  
  // String.ReplaceCharAt
  {
    String mystring = "Hello";
    String changed = mystring.ReplaceCharAt(2, 'm');
    tap.is(changed, "Hemlo", "String.ReplaceCharAt test");
    
    // UTF-8 specific test
    String utfString = "ƒÑƒÜƒàƒäƒåƒéƒêƒíƒîƒñƒòƒöƒúƒûƒ†ƒ¢ƒ§ƒ¶ƒ®";
    String utfChanged = utfString.ReplaceCharAt(3, 's');  // Replacing 'ƒä' with 's'
    tap.is(utfChanged, "ƒÑƒÜƒàsƒåƒéƒêƒíƒîƒñƒòƒöƒúƒûƒ†ƒ¢ƒ§ƒ¶ƒ®", "String.ReplaceCharAt UTF-8 test");
  }
  
  // String.StartsWith
  {    
    String myString = "Hello from the script!";
    tap.ok(myString.StartsWith("Hello", eCaseInsensitive), "String.StartsWith: identical, case insensitive");
    tap.ok(myString.StartsWith("Hello", eCaseSensitive), "String.StartsWith: identical, case sensitive");
    tap.ok(myString.StartsWith("HELLO", eCaseInsensitive), "String.StartsWith: case diff, case insensitive");
    tap.nok(myString.StartsWith("HELLO", eCaseSensitive), "String.StartsWith: case diff, case sensitive");
    
    // UTF-8 specific test
    String utfString = "Gr√º√üe von M√ºnchen!";
    tap.ok(utfString.StartsWith("Gr√º√üe", eCaseInsensitive), "String.StartsWith: UTF-8 identical, case insensitive");
    tap.ok(utfString.StartsWith("Gr√º√üe", eCaseSensitive), "String.StartsWith: UTF-8 identical, case sensitive");
    tap.ok(utfString.StartsWith("GR√ú√üE", eCaseInsensitive), "String.StartsWith: UTF-8 case diff, case insensitive");
    tap.nok(utfString.StartsWith("GR√ú√üE", eCaseSensitive), "String.StartsWith: UTF-8 case diff, case sensitive");
  }
  
  // String.Substring
  {
    String mystring = "Hello World!";
    String substring = mystring.Substring(3, 5);
    tap.is(substring, "lo Wo", "String.Substring test");    
  }
  
  // String.Truncate
  {
    String mystring = "Hello World!";
    String truncated = mystring.Truncate(7);
    tap.is(truncated, "Hello W", "String.Truncate test");   
  }
  
  // String.UpperCase
  {
    String mystring = "THIS is a test string";
    String uppercased = mystring.UpperCase();
    tap.is(uppercased, "THIS IS A TEST STRING", "String.UpperCase test");  
    
    // UTF-8 specific test
    String utfString = "fu√üg√§nger√ºberg√§nge";
    String utfUppercased = utfString.UpperCase();
    tap.is(utfUppercased, "FU√üG√ÑNGER√úBERG√ÑNGE", "String.UpperCase UTF-8 test");
  }
  
  // String.AsFloat
  {
    String text1, text2;
    float number1, number2;
    text1 = "57.362";
    text2 = "Hello";
    number1 = text1.AsFloat;
    number2 = text2.AsFloat;
    tap.is_float(number1, 57.362, 0.0001, "String.AsFloat test with ''57.362''");
    tap.is_float(number2, 0.0, 0.0001, "String.AsFloat test with ''Hello''");
  }
  
  // String.AsInt
  {
    String text1, text2;
    int number1, number2;
    text1 = "53";
    text2 = "Hello";
    number1 = text1.AsInt;
    number2 = text2.AsInt;
    tap.is_int(number1, 53, "String.AsInt test with ''53''");
    tap.is_int(number2, 0, "String.AsInt test with ''Hello''");
  }
  
  // String.Chars
  {
    String text = "This is my string.";
    tap.is(String.Format("%c",text.Chars[3]), "s", "String.Chars test");
  }
  
  // String.Length
  {
    String text = "This is my string.";
    tap.is_int(text.Length, 18, "String.Length test");
  }

  tap.Comment("end String tests");
}