// Test Set Module Script
int GetTestSetCount()
{
  return 8
  + 5 * 4 // contains
  + 5 * 4 // contains unicode
  ;
}

void TestSetContains(Set* set, bool sorted, bool casesensitive, String test_name)
{
  set.Clear();
  set.Add("Key1");
  set.Add("key2");
  
  tap.ok(set.Contains("Key1"), String.Format("%s: Contains matches exact key (ok 1)", test_name));
  tap.ok(set.Contains("key2"), String.Format("%s: Contains matches exact key (ok 2)", test_name));
  tap.nok(set.Contains("Yey1"), String.Format("%s: Contains fails at wrong key", test_name));
  if (casesensitive)
  {
    tap.nok(set.Contains("kEy1"), String.Format("%s: Contains should be case-sensitive (nok 1)", test_name));
    tap.nok(set.Contains("KeY2"), String.Format("%s: Contains should be case-sensitive (nok 2)", test_name));
  }
  else
  {
    tap.ok(set.Contains("kEy1"), String.Format("%s: Contains should be case-insensitive (ok 1)", test_name));
    tap.ok(set.Contains("KeY2"), String.Format("%s: Contains should be case-insensitive (ok 2)", test_name));
  }
}

void TestSetContainsUnicode(Set* set, bool sorted, bool casesensitive, String test_name)
{
  set.Clear();
  set.Add("FUßGÄNGERÜBERGÄNGE_1");
  set.Add("fußgängerübergänge_2");
  
  tap.ok(set.Contains("FUßGÄNGERÜBERGÄNGE_1"), String.Format("%s: Contains matches exact key (ok 1)", test_name));
  tap.ok(set.Contains("fußgängerübergänge_2"), String.Format("%s: Contains matches exact key (ok 2)", test_name));
  tap.nok(set.Contains("FUßGÄNGERÄBERGÄNGE_1"), String.Format("%s: Contains fails at wrong key", test_name));
  if (casesensitive)
  {
    tap.nok(set.Contains("FUßgäNGERüberGÄNGE_1"), String.Format("%s: Contains should be case-sensitive (nok 1)", test_name));
    tap.nok(set.Contains("fußGÄngerÜBERgänge_2"), String.Format("%s: Contains should be case-sensitive (nok 2)", test_name));
  }
  else
  {
    tap.ok(set.Contains("FUßgäNGERüberGÄNGE_1"), String.Format("%s: Contains should be case-insensitive (ok 1)", test_name));
    tap.ok(set.Contains("fußGÄngerÜBERgänge_2"), String.Format("%s: Contains should be case-insensitive (ok 2)", test_name));
  }
}

void TestSet()
{  
  tap.Comment("start Set tests");
  
  // Create a set, add items, and check if Contains works
  {
    Set* mySet = Set.Create();
    mySet.Add("item1");

    tap.ok(mySet.Contains("item1"), "Contains should return true for added item");
    tap.ok(!mySet.Contains("non-existent-item"), "Contains should return false for non-existent item");
  }

  // Add and Remove items from Set
  {
    Set* mySet = Set.Create();
    mySet.Add("item1");

    tap.ok(mySet.Contains("item1"), "Contains should return true before removal");

    mySet.Remove("item1");
    tap.ok(!mySet.Contains("item1"), "Contains should return false after removal");
  }

  // GetItemsAsArray
  {
    Set* mySet = Set.Create(eSorted, eCaseSensitive);
    mySet.Add("item1");
    mySet.Add("item2");

    String items[] = mySet.GetItemsAsArray();
    tap.is_int(mySet.ItemCount, 2, "GetItemsAsArray has correct item count");
    tap.is(items[0], "item1", "GetItemsAsArray should return items in the correct order (i=0)");
    tap.is(items[1], "item2", "GetItemsAsArray should return items in the correct order (i=1)");
  }

  // Clear Set
  {
    Set* mySet = Set.Create();
    mySet.Add("item1");
    mySet.Add("item2");

    mySet.Clear();
    tap.ok(mySet.ItemCount == 0, "Clear should remove all items from the set");
  }
  
  // Contains with different SortStyles and CompareStyles
  {
    Set* sortedCaseSensitiveSet = Set.Create(eSorted, eCaseSensitive);
    TestSetContains(sortedCaseSensitiveSet, true, true, "Set (sorted, case)");
    Set* sortedCaseInsensitiveSet = Set.Create(eSorted, eCaseInsensitive);
    TestSetContains(sortedCaseInsensitiveSet, true, false, "Set (sorted, nocase)");
    Set* unsortedCaseSensitiveSet = Set.Create(eNonSorted, eCaseSensitive);
    TestSetContains(unsortedCaseSensitiveSet, false, true, "Set (unsorted, case)");
    Set* unsortedCaseInsensitiveSet = Set.Create(eNonSorted, eCaseInsensitive);
    TestSetContains(unsortedCaseInsensitiveSet, false, false, "Set (unsorted, nocase)");
  }

  // Contains with different SortStyles and CompareStyles, Unicode strings
  {
    Set* sortedCaseSensitiveSet = Set.Create(eSorted, eCaseSensitive);
    TestSetContainsUnicode(sortedCaseSensitiveSet, true, true, "Set (unicode, sorted, case)");
    Set* sortedCaseInsensitiveSet = Set.Create(eSorted, eCaseInsensitive);
    TestSetContainsUnicode(sortedCaseInsensitiveSet, true, false, "Set (unicode, sorted, nocase)");
    Set* unsortedCaseSensitiveSet = Set.Create(eNonSorted, eCaseSensitive);
    TestSetContainsUnicode(unsortedCaseSensitiveSet, false, true, "Set (unicode, unsorted, case)");
    Set* unsortedCaseInsensitiveSet = Set.Create(eNonSorted, eCaseInsensitive);
    TestSetContainsUnicode(unsortedCaseInsensitiveSet, false, false, "Set (unicode, unsorted, nocase)");
  }

  tap.Comment("end Set tests");
}