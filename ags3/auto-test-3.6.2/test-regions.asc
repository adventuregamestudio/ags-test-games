// Test Regions Module Script
int GetTestRegionsCount()
{
  return 0
  + 7 // getatscreenxy
  ;
}

void TestRegions()
{
  tap.Comment("start Regions tests");
  
  region[1].Enabled = true;
  Region* testH;
  testH = Region.GetAtRoomXY(5, 5);
  tap.ok(testH == region[0], "Region.GetAtRoomXY: hit-test empty place");
  testH = Region.GetAtRoomXY(30, 180);
  tap.ok(testH == region[1], "Region.GetAtRoomXY: hit-test region");
  region[1].Enabled = false;
  testH = Region.GetAtRoomXY(30, 180);
  tap.ok(testH == region[0], "Region.GetAtRoomXY: can't hit disabled region");
  region[1].Enabled = true;
  
  testH = Region.GetAtScreenXY(5, 5);
  tap.ok(testH == region[0], "Region.GetAtScreenXY: hit-test empty place");
  testH = Region.GetAtScreenXY(30, 180);
  tap.ok(testH == region[1], "Region.GetAtScreenXY: hit-test region (screen pos match room pos)");
  region[1].Enabled = false;
  testH = Region.GetAtScreenXY(30, 180);
  tap.ok(testH == region[0], "Region.GetAtScreenXY: can't hit disabled region");
  region[1].Enabled = true;
  
  // Test "scrolling" room
  Game.Camera.SetSize(80, 80);
  Game.Camera.SetAt(0, 200 - 80);
  Screen.Viewport.SetPosition(0, 0, 80, 80);
  testH = Region.GetAtScreenXY(30, 180 - (200 - 80));
  tap.ok(testH == region[1], "Region.GetAtScreenXY: hit-test region (camera offset)");
  
  // CLEANUP
  Game.Camera.SetSize(Room.Width, Room.Height);
  Screen.Viewport.SetPosition(0, 0, Screen.Width, Screen.Height);
  
  tap.Comment("end Regions tests");
}
