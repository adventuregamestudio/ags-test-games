// Test File Directory Module Script
int GetTestSaveListCount()
{
  return 6 * 4;
}

#define SAVE_LIST_SIZE 3

void CleanupTestSaveList()
{
  // Delete any existing save slots
  int slots[] = Game.GetSaveSlots(0, 999, eSaveGameSort_None, eSortNoDirection);
  for (int i = 0; i < slots.Length; i++)
  {
    DeleteSaveSlot(i);
  }
}

void PrepareTestSaveList(int index)
{
  // Sadly, engine's implementation cannot distinguish filetimes smaller than 1 second, 
  // therefore we must wait 1 second between each save
  if (index != 0)
  {
    Wait(GetGameSpeed());
  }
  // We need to test sorting in various orders:
  // - slot number, 
  // - description
  // - file time
  // so the saves should be mixed up "randomly".
  int slot = index;
  switch (slot)
  {
  case 0: SaveGameSlot(2, "bbb"); break;
  case 1: SaveGameSlot(0, "ccc"); break;
  case 2: SaveGameSlot(1, "aaa"); break;
  }
}

void RunTestSaveList()
{
  ListBox1.Clear();
  ListBox1.FillSaveGameList(0, SAVE_LIST_SIZE - 1, eSaveGameSort_Number, eSortAscending);
  tap.is_int(ListBox1.ItemCount, SAVE_LIST_SIZE, "ListBox1.FillSaveGameList: (by number, asc) save count");
  tap.is_int(ListBox1.SaveGameSlots[0], 0, "ListBox1.FillSaveGameList: (by number, asc) item 0");
  tap.is_int(ListBox1.SaveGameSlots[1], 1, "ListBox1.FillSaveGameList: (by number, asc) item 1");
  tap.is_int(ListBox1.SaveGameSlots[2], 2, "ListBox1.FillSaveGameList: (by number, asc) item 2");
  
  ListBox1.Clear();
  ListBox1.FillSaveGameList(0, SAVE_LIST_SIZE - 1, eSaveGameSort_Number, eSortDescending);
  tap.is_int(ListBox1.ItemCount, SAVE_LIST_SIZE, "ListBox1.FillSaveGameList: (by number, dsc) save count");
  tap.is_int(ListBox1.SaveGameSlots[0], 2, "ListBox1.FillSaveGameList: (by number, dsc) item 0");
  tap.is_int(ListBox1.SaveGameSlots[1], 1, "ListBox1.FillSaveGameList: (by number, dsc) item 1");
  tap.is_int(ListBox1.SaveGameSlots[2], 0, "ListBox1.FillSaveGameList: (by number, dsc) item 2");
  
  ListBox1.Clear();
  ListBox1.FillSaveGameList(0, SAVE_LIST_SIZE - 1, eSaveGameSort_Description, eSortAscending);
  tap.is_int(ListBox1.ItemCount, SAVE_LIST_SIZE, "ListBox1.FillSaveGameList: (by desc, asc) save count");
  tap.is_int(ListBox1.SaveGameSlots[0], 1, "ListBox1.FillSaveGameList: (by desc, asc) item 0");
  tap.is_int(ListBox1.SaveGameSlots[1], 2, "ListBox1.FillSaveGameList: (by desc, asc) item 1");
  tap.is_int(ListBox1.SaveGameSlots[2], 0, "ListBox1.FillSaveGameList: (by desc, asc) item 2");
  
  ListBox1.Clear();
  ListBox1.FillSaveGameList(0, SAVE_LIST_SIZE - 1, eSaveGameSort_Description, eSortDescending);
  tap.is_int(ListBox1.ItemCount, SAVE_LIST_SIZE, "ListBox1.FillSaveGameList: (by desc, dsc) save count");
  tap.is_int(ListBox1.SaveGameSlots[0], 0, "ListBox1.FillSaveGameList: (by desc, dsc) item 0");
  tap.is_int(ListBox1.SaveGameSlots[1], 2, "ListBox1.FillSaveGameList: (by desc, dsc) item 1");
  tap.is_int(ListBox1.SaveGameSlots[2], 1, "ListBox1.FillSaveGameList: (by desc, dsc) item 2");
  
  ListBox1.Clear();
  ListBox1.FillSaveGameList(0, SAVE_LIST_SIZE - 1, eSaveGameSort_Time, eSortAscending);
  tap.is_int(ListBox1.ItemCount, SAVE_LIST_SIZE, "ListBox1.FillSaveGameList: (by time, asc) save count");
  tap.is_int(ListBox1.SaveGameSlots[0], 2, "ListBox1.FillSaveGameList: (by time, asc) item 0");
  tap.is_int(ListBox1.SaveGameSlots[1], 0, "ListBox1.FillSaveGameList: (by time, asc) item 1");
  tap.is_int(ListBox1.SaveGameSlots[2], 1, "ListBox1.FillSaveGameList: (by time, asc) item 2");
  
  ListBox1.Clear();
  ListBox1.FillSaveGameList(0, SAVE_LIST_SIZE - 1, eSaveGameSort_Time, eSortDescending);
  tap.is_int(ListBox1.ItemCount, SAVE_LIST_SIZE, "ListBox1.FillSaveGameList: (by time, dsc) save count");
  tap.is_int(ListBox1.SaveGameSlots[0], 1, "ListBox1.FillSaveGameList: (by time, dsc) item 0");
  tap.is_int(ListBox1.SaveGameSlots[1], 0, "ListBox1.FillSaveGameList: (by time, dsc) item 1");
  tap.is_int(ListBox1.SaveGameSlots[2], 2, "ListBox1.FillSaveGameList: (by time, dsc) item 2");
}

int TestSaveList(int counter)
{
  if (counter == 0)
  {
    tap.Comment("start SaveList tests");
    CleanupTestSaveList();
  }
  
  if (counter < SAVE_LIST_SIZE)
  {
    PrepareTestSaveList(counter);
  }
  else if (counter == SAVE_LIST_SIZE)
  {
    RunTestSaveList();
    CleanupTestSaveList();
  }
  
  counter++;
  if (counter <= SAVE_LIST_SIZE)
  {
    return counter;
  }
  else
  {
    tap.Comment("end SaveList tests");
    return -1;
  }
}
