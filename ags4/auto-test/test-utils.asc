// Test GUI Operations Module Script
int GetTestUtilsCount()
{
  bool can_locale_tests = System.LocaleName != "";
  
  int test_count =
    8 * 4 // string sort
  + 3 * 2 // int sort
  + 3 * 2 // float sort
  ;
  if (can_locale_tests)
    test_count += 8 * 4;
  return test_count;
}

String[] FillStringArray()
{
  String arr[] = new String[8];
  arr[0] = "CCC";
  arr[1] = "AAA";
  arr[2] = "BBB";
  arr[3] = "ÄÄÄ";
  arr[4] = "ccc";
  arr[5] = "aaa";
  arr[6] = "bbb";
  arr[7] = "äää";
  return arr;
}

int[] FillIntArray()
{
  int arr[] = new int[3];
  arr[0] = 2;
  arr[1] = -1;
  arr[2] = 1;
  return arr;
}

float[] FillFloatArray()
{
  float arr[] = new float[3];
  arr[0] = 1.8;
  arr[1] = -0.4;
  arr[2] = 0.6;
  return arr;
}

void TestUtils()
{
  bool can_locale_tests = System.LocaleName != "";
  
  tap.Comment("start Utils tests");
  
  {
    String arr[] = FillStringArray();
    Utils.SortStrings(arr, eCaseSensitive, eSortAscending);
    tap.is(arr[0], "AAA", "Utils.SortStrings: (case, asc) item 0");
    tap.is(arr[1], "BBB", "Utils.SortStrings: (case, asc) item 1");
    tap.is(arr[2], "CCC", "Utils.SortStrings: (case, asc) item 2");
    tap.is(arr[3], "aaa", "Utils.SortStrings: (case, asc) item 3");
    tap.is(arr[4], "bbb", "Utils.SortStrings: (case, asc) item 4");
    tap.is(arr[5], "ccc", "Utils.SortStrings: (case, asc) item 5");
    tap.is(arr[6], "ÄÄÄ", "Utils.SortStrings: (case, asc) item 6");
    tap.is(arr[7], "äää", "Utils.SortStrings: (case, asc) item 7");
    
    arr = FillStringArray();
    Utils.SortStrings(arr, eCaseSensitive, eSortDescending);
    tap.is(arr[0], "äää", "Utils.SortStrings: (case, dsc) item 0");
    tap.is(arr[1], "ÄÄÄ", "Utils.SortStrings: (case, dsc) item 1");
    tap.is(arr[2], "ccc", "Utils.SortStrings: (case, dsc) item 2");
    tap.is(arr[3], "bbb", "Utils.SortStrings: (case, dsc) item 3");
    tap.is(arr[4], "aaa", "Utils.SortStrings: (case, dsc) item 4");
    tap.is(arr[5], "CCC", "Utils.SortStrings: (case, dsc) item 5");
    tap.is(arr[6], "BBB", "Utils.SortStrings: (case, dsc) item 6");
    tap.is(arr[7], "AAA", "Utils.SortStrings: (case, dsc) item 7");
      
    arr = FillStringArray();
    Utils.SortStrings(arr, eCaseInsensitive, eSortAscending);
    tap.is(arr[0], "AAA", "Utils.SortStrings: (nocase, asc) item 0");
    tap.is(arr[1], "aaa", "Utils.SortStrings: (nocase, asc) item 1");
    tap.is(arr[2], "BBB", "Utils.SortStrings: (nocase, asc) item 2");
    tap.is(arr[3], "bbb", "Utils.SortStrings: (nocase, asc) item 3");
    tap.is(arr[4], "CCC", "Utils.SortStrings: (nocase, asc) item 4");
    tap.is(arr[5], "ccc", "Utils.SortStrings: (nocase, asc) item 5");
    tap.is(arr[6], "ÄÄÄ", "Utils.SortStrings: (nocase, asc) item 6");
    tap.is(arr[7], "äää", "Utils.SortStrings: (nocase, asc) item 7");
      
    arr = FillStringArray();
    Utils.SortStrings(arr, eCaseInsensitive, eSortDescending);
    tap.is(arr[0], "ÄÄÄ", "Utils.SortStrings: (nocase, dsc) item 0");
    tap.is(arr[1], "äää", "Utils.SortStrings: (nocase, dsc) item 1");
    tap.is(arr[2], "CCC", "Utils.SortStrings: (nocase, dsc) item 2");
    tap.is(arr[3], "ccc", "Utils.SortStrings: (nocase, dsc) item 3");
    tap.is(arr[4], "BBB", "Utils.SortStrings: (nocase, dsc) item 4");
    tap.is(arr[5], "bbb", "Utils.SortStrings: (nocase, dsc) item 5");
    tap.is(arr[6], "AAA", "Utils.SortStrings: (nocase, dsc) item 6");
    tap.is(arr[7], "aaa", "Utils.SortStrings: (nocase, dsc) item 7");
    
    if (can_locale_tests)
    {
      arr = FillStringArray();
      Utils.SortStrings(arr, eCaseSensitiveLocaleAware, eSortAscending);
      tap.is(arr[0], "aaa", "Utils.SortStrings: (locale aware case, asc) item 0");
      tap.is(arr[1], "AAA", "Utils.SortStrings: (locale aware case, asc) item 1");
      tap.is(arr[2], "äää", "Utils.SortStrings: (locale aware case, asc) item 2");
      tap.is(arr[3], "ÄÄÄ", "Utils.SortStrings: (locale aware case, asc) item 3");
      tap.is(arr[4], "bbb", "Utils.SortStrings: (locale aware case, asc) item 4");
      tap.is(arr[5], "BBB", "Utils.SortStrings: (locale aware case, asc) item 5");
      tap.is(arr[6], "ccc", "Utils.SortStrings: (locale aware case, asc) item 6");
      tap.is(arr[7], "CCC", "Utils.SortStrings: (locale aware case, asc) item 7");
      
      arr = FillStringArray();
      Utils.SortStrings(arr, eCaseSensitiveLocaleAware, eSortDescending);
      tap.is(arr[0], "CCC", "Utils.SortStrings: (locale aware case, desc) item 0");
      tap.is(arr[1], "ccc", "Utils.SortStrings: (locale aware case, desc) item 1");
      tap.is(arr[2], "BBB", "Utils.SortStrings: (locale aware case, desc) item 2");
      tap.is(arr[3], "bbb", "Utils.SortStrings: (locale aware case, desc) item 3");
      tap.is(arr[4], "ÄÄÄ", "Utils.SortStrings: (locale aware case, desc) item 4");
      tap.is(arr[5], "äää", "Utils.SortStrings: (locale aware case, desc) item 5");
      tap.is(arr[6], "AAA", "Utils.SortStrings: (locale aware case, desc) item 6");
      tap.is(arr[7], "aaa", "Utils.SortStrings: (locale aware case, desc) item 7");
      
      arr = FillStringArray();
      Utils.SortStrings(arr, eCaseInsensitiveLocaleAware, eSortAscending);
      tap.is(arr[0], "AAA", "Utils.SortStrings: (locale aware nocase, asc) item 0");
      tap.is(arr[1], "aaa", "Utils.SortStrings: (locale aware nocase, asc) item 1");
      tap.is(arr[2], "ÄÄÄ", "Utils.SortStrings: (locale aware nocase, asc) item 2");
      tap.is(arr[3], "äää", "Utils.SortStrings: (locale aware nocase, asc) item 3");
      tap.is(arr[4], "BBB", "Utils.SortStrings: (locale aware nocase, asc) item 4");
      tap.is(arr[5], "bbb", "Utils.SortStrings: (locale aware nocase, asc) item 5");
      tap.is(arr[6], "CCC", "Utils.SortStrings: (locale aware nocase, asc) item 6");
      tap.is(arr[7], "ccc", "Utils.SortStrings: (locale aware nocase, asc) item 7");
      
      arr = FillStringArray();
      Utils.SortStrings(arr, eCaseInsensitiveLocaleAware, eSortDescending);
      tap.is(arr[0], "CCC", "Utils.SortStrings: (locale aware nocase, desc) item 0");
      tap.is(arr[1], "ccc", "Utils.SortStrings: (locale aware nocase, desc) item 1");
      tap.is(arr[2], "BBB", "Utils.SortStrings: (locale aware nocase, desc) item 2");
      tap.is(arr[3], "bbb", "Utils.SortStrings: (locale aware nocase, desc) item 3");
      tap.is(arr[4], "ÄÄÄ", "Utils.SortStrings: (locale aware nocase, desc) item 4");
      tap.is(arr[5], "äää", "Utils.SortStrings: (locale aware nocase, desc) item 5");
      tap.is(arr[6], "AAA", "Utils.SortStrings: (locale aware nocase, desc) item 6");
      tap.is(arr[7], "aaa", "Utils.SortStrings: (locale aware nocase, desc) item 7");
    }
  }
  
  {
    int arr[] = FillIntArray();
    Utils.SortInts(arr, eSortAscending);
    tap.is_int(arr[0], -1, "Utils.SortInts: (asc) item 0");
    tap.is_int(arr[1], 1, "Utils.SortInts: (asc) item 1");
    tap.is_int(arr[2], 2, "Utils.SortInts: (asc) item 2");
    
    arr = FillIntArray();
    Utils.SortInts(arr, eSortDescending);
    tap.is_int(arr[0], 2, "Utils.SortInts: (dsc) item 0");
    tap.is_int(arr[1], 1, "Utils.SortInts: (dsc) item 1");
    tap.is_int(arr[2], -1, "Utils.SortInts: (dsc) item 2");
  }
  
  {
    float arr[] = FillFloatArray();
    Utils.SortFloats(arr, eSortAscending);
    tap.is_float(arr[0], -0.4, 0.0001, "Utils.SortFloats: (asc) item 0");
    tap.is_float(arr[1], 0.6, 0.0001, "Utils.SortFloats: (asc) item 1");
    tap.is_float(arr[2], 1.8, 0.0001, "Utils.SortFloats: (asc) item 2");
    
    arr = FillFloatArray();
    Utils.SortFloats(arr, eSortDescending);
    tap.is_float(arr[0], 1.8, 0.0001, "Utils.SortFloats: (dsc) item 0");
    tap.is_float(arr[1], 0.6, 0.0001, "Utils.SortFloats: (dsc) item 1");
    tap.is_float(arr[2], -0.4, 0.0001, "Utils.SortFloats: (dsc) item 2");
  }
  
  tap.Comment("end Utils tests");
}
