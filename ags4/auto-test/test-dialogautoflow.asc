// Test Dialog Auto Flow Module Script
int GetTestDialogAutoFlowCount()
{
  return 9;
}

int TestDialogAutoFlow(int counter)
{
  if (counter == 0)
  {
    tap.Comment("start DialogAutoFlow tests");
    DialogFlowTestStep = 0;
    game.show_single_dialog_option = 0;
    dDialogAutoFlow1.Start();
  }
  else
  {
    DialogFlowTestStep++;
    tap.is_int(DialogFlowTestStep, 9, "Dialog Auto Flow: post-step");
  }
  
  counter++;
  if (counter < 2)
  {
    return counter;
  }
  else
  {
    tap.Comment("end DialogAutoFlow tests");
    return -1;
  }
}
