// Test Dialog Custom Options Module Script

// Unfortunately, there's no way in AGS to switch between dialog option mode
// at runtime. We either have respective callbacks in script or not...
// Perhaps if we had such ability, we would be able to test all option types.
// But for now we test only custom drawing.

int GetTestDialogCustomOptionsCount()
{
  return 1 // looks
    + 3    // stage checks
  ;
}

#define SPRITE_USE_FOR_TEST 5

bool Check_GetDimensions;
bool Check_Render;
bool Check_RepExec;

function dialog_options_get_dimensions(DialogOptionsRenderingInfo *info)
{
    // Create a 200x200 dialog options area at (50,100)
  info.X = 50;
  info.Y = 100;
  info.Width = 200;
  info.Height = 200;
  
  if (!Check_GetDimensions)
  {
    Check_GetDimensions = true;
  }
}

function dialog_options_render(DialogOptionsRenderingInfo *info)
{
  info.Surface.Clear(0);
  info.Surface.DrawImage(5, 5, SPRITE_USE_FOR_TEST);
  
  if (!Check_Render)
  {
    Check_Render = true;
  }
}

function dialog_options_repexec(DialogOptionsRenderingInfo *info)
{
  tap.ok(
    GfxComparer.TakeScreenshotAndMatchSprite(info.X + 5, info.Y + 5,
      Game.SpriteWidth[SPRITE_USE_FOR_TEST], Game.SpriteHeight[SPRITE_USE_FOR_TEST], 
      SPRITE_USE_FOR_TEST), 
    "DialogCustomOptions: drawn looks");
    
  if (!Check_RepExec)
  {
    Check_RepExec = true;
  }
  
  info.ActiveOptionID = 1;
  info.RunActiveOption();
}

void DoPostDialogCheckups()
{
  tap.ok(Check_GetDimensions, "DialogCustomOptions: get_dimensions run at least once");
  tap.ok(Check_Render, "DialogCustomOptions: render run at least once");
  tap.ok(Check_RepExec, "DialogCustomOptions: repexec run at least once");
}

int TestDialogCustomOptionsDelayed(int counter)
{
  if (counter == 0)
  {
    tap.Comment("start Dialog Custom Options tests");
    Game.Speed = 1000;
    TestHelpers.HideGUIs();
    TestHelpers.HideRoomObjects();
    dDialogStop.Start();
    counter++;
    return counter;
  }
  else if (counter == 1)
  {
    DoPostDialogCheckups();
    tap.Comment("end Dialog Custom Options tests");
    return -1;
  }
}
