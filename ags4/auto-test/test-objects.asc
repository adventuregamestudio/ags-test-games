// Test Objects Module Script
int GetTestObjectsCount()
{
  return 0
  + 5 // 3.6.3 properties
  + 9 // getatscreenxy
  + 1 // graphic pos
  + 8 // view frames
  ;
}

void TestObjectProperties(Object *testObject)
{
  testObject.AudioPanning = -20;
  testObject.AudioSpeed = 2000;
  testObject.AudioVolume = 50;
  testObject.BlockingRectX = 2;
  testObject.BlockingRectY = 4;
  tap.is_int(testObject.AudioPanning, -20, "Object.AudioPanning");
  tap.is_int(testObject.AudioSpeed, 2000, "Object.AudioSpeed");
  tap.is_int(testObject.AudioVolume, 50, "Object.AudioVolume");
  tap.is_int(testObject.BlockingRectX, 2, "Object.BlockingRectX");
  tap.is_int(testObject.BlockingRectY, 4, "Object.BlockingRectY");
}

#define SPRITE_DEFAULT 7

void TestGetAtXY(Object *testObject)
{
  Object* testO;
  testObject.Clickable = true;
  testObject.Visible = true;
  testObject.Graphic = SPRITE_DEFAULT;
  testObject.X = 100;
  testObject.Y = 100;
  Wait(1); // must re-draw, because GetAt... uses cached object size! :[
  testO = Object.GetAtRoomXY(10, 10);
  tap.ok(testO == null, "Object.GetAtRoomXY: hit-test empty place");
  testO = Object.GetAtRoomXY(105, 95);
  tap.ok(testO == testObject, "Object.GetAtRoomXY: hit-test object");
  testObject.Clickable = false;
  testO = Object.GetAtRoomXY(105, 95);
  tap.ok(testO == null, "Object.GetAtRoomXY: can't hit non-clickable object");
  testO = Object.GetAtRoomXY(105, 95, eHit_Any);
  tap.ok(testO == testObject, "Object.GetAtRoomXY: hit non-clickable object in eHit_Any mode");
  testObject.Clickable = true;
  
  testO = Object.GetAtScreenXY(5, 5);
  tap.ok(testO == null, "Object.GetAtScreenXY: hit-test empty place");
  testO = Object.GetAtScreenXY(105, 95);
  tap.ok(testO == testObject, "Object.GetAtScreenXY: hit-test object (screen pos match room pos)");
  testObject.Clickable = false;
  testO = Object.GetAtScreenXY(105, 95);
  tap.ok(testO == null, "Object.GetAtScreenXY: can't hit non-clickable object");
  testO = Object.GetAtScreenXY(105, 95, eHit_Any);
  tap.ok(testO == testObject, "Object.GetAtScreenXY: hit non-clickable object in eHit_Any mode");
  testObject.Clickable = true;
  
  // Test "scrolling" room
  Game.Camera.SetSize(80, 80);
  Game.Camera.SetAt(80, 80);
  Screen.Viewport.SetPosition(0, 0, 80, 80);
  testO = Object.GetAtScreenXY(105 - 80, 95 - 80);
  tap.ok(testO == testObject, "Object.GetAtScreenXY: hit-test hotspot (camera offset)");
  
  // CLEANUP
  Game.Camera.SetSize(Room.Width, Room.Height);
  Screen.Viewport.SetPosition(0, 0, Screen.Width, Screen.Height);
}

void _TestObjectRenderF(Object *testObject, int sprite_num, eFlipDirection flip, const string test_name)
{
  Wait(1); // let engine redraw
  int sprite_w = Game.SpriteWidth[sprite_num];
  int sprite_h = Game.SpriteHeight[sprite_num];
  int sprite_x = testObject.X;
  int sprite_y = testObject.Y - sprite_h + 1;
  tap.ok(GfxComparer.TakeScreenshotAndMatchSprite(sprite_x, sprite_y, sprite_w, sprite_h, sprite_num, flip), test_name);
}

void _TestObjectRender(Object *testObject, int sprite_num, const string test_name)
{
  _TestObjectRenderF(testObject, sprite_num, eFlipNone, test_name);
}

void _TestObjectViewFrame(Object *testObject, int view, int loop, int frame, const string test_name)
{
  testObject.SetView(view, loop, frame);
  ViewFrame* vf = Game.GetViewFrame(view, loop, frame);
  _TestObjectRenderF(testObject, vf.Graphic, vf.Flipped, test_name);
}

void TestGraphicPosition(Object *testObject)
{
  testObject.Graphic = SPRITE_DEFAULT;
  _TestObjectRender(testObject, SPRITE_DEFAULT, "Object: graphic position");
}

void TestViewRender(Object *testObject)
{
  _TestObjectViewFrame(testObject, VFLIP, 0, 0, "Object: view frame 0, normal");
  _TestObjectViewFrame(testObject, VFLIP, 0, 1, "Object: view frame 1, normal");
  _TestObjectViewFrame(testObject, VFLIP, 0, 2, "Object: view frame 2, h-flip");
  _TestObjectViewFrame(testObject, VFLIP, 0, 3, "Object: view frame 3, h-flip");
  _TestObjectViewFrame(testObject, VFLIP, 0, 4, "Object: view frame 4, v-flip");
  _TestObjectViewFrame(testObject, VFLIP, 0, 5, "Object: view frame 5, v-flip");
  _TestObjectViewFrame(testObject, VFLIP, 0, 6, "Object: view frame 6, hv-flip");
  _TestObjectViewFrame(testObject, VFLIP, 0, 7, "Object: view frame 7, hv-flip");
}

void TestObjects()
{
  tap.Comment("start Object tests");
  tap.Comment(String.Format("System.HardwareAcceleration = %d", System.HardwareAcceleration));
  
  TestHelpers.HideGUIs();
  TestHelpers.HideRoomObjects();
  
  Object* oTestObject = object[0];
  
  TestObjectProperties(oTestObject);
  TestGetAtXY(oTestObject);
  
  oTestObject.X = 100;
  oTestObject.Y = 100;
  oTestObject.Visible = true;
  oTestObject.Transparency = 0;
  
  TestGraphicPosition(oTestObject);
  TestViewRender(oTestObject);
  
  tap.Comment("end Object tests");
}
