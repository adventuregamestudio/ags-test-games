// Test GUI Operations Module Script
int GetTestGUIOperationsCount()
{
  return 0
    + 4 * 7 // listbox
    + 8     // button frame audio + events
  ;
}

void FillListBox(ListBox* lbox)
{
  lbox.Clear();
  lbox.AddItem("CCC");
  lbox.AddItem("AAA");
  lbox.AddItem("BBB");
  lbox.AddItem("ccc");
  lbox.AddItem("aaa");
  lbox.AddItem("bbb");
}

void TestListBoxOperations()
{
  FillListBox(ListBox1);
  ListBox1.SortItems(eCaseSensitive, eSortAscending);
  tap.is_int(ListBox1.ItemCount, 6, "ListBox.SortItems: (case, asc) item count");
  tap.is(ListBox1.Items[0], "AAA", "ListBox.SortItems: (case, asc) item 0");
  tap.is(ListBox1.Items[1], "BBB", "ListBox.SortItems: (case, asc) item 1");
  tap.is(ListBox1.Items[2], "CCC", "ListBox.SortItems: (case, asc) item 2");
  tap.is(ListBox1.Items[3], "aaa", "ListBox.SortItems: (case, asc) item 3");
  tap.is(ListBox1.Items[4], "bbb", "ListBox.SortItems: (case, asc) item 4");
  tap.is(ListBox1.Items[5], "ccc", "ListBox.SortItems: (case, asc) item 5");
  
  FillListBox(ListBox1);
  ListBox1.SortItems(eCaseSensitive, eSortDescending);
  tap.is_int(ListBox1.ItemCount, 6, "ListBox.SortItems: (case, dsc) item count");
  tap.is(ListBox1.Items[0], "ccc", "ListBox.SortItems: (case, dsc) item 0");
  tap.is(ListBox1.Items[1], "bbb", "ListBox.SortItems: (case, dsc) item 1");
  tap.is(ListBox1.Items[2], "aaa", "ListBox.SortItems: (case, dsc) item 2");
  tap.is(ListBox1.Items[3], "CCC", "ListBox.SortItems: (case, dsc) item 3");
  tap.is(ListBox1.Items[4], "BBB", "ListBox.SortItems: (case, dsc) item 4");
  tap.is(ListBox1.Items[5], "AAA", "ListBox.SortItems: (case, dsc) item 5");
  
  FillListBox(ListBox1);
  ListBox1.SortItems(eCaseInsensitive, eSortAscending);
  tap.is_int(ListBox1.ItemCount, 6, "ListBox.SortItems: (nocase, asc) item count");
  tap.is(ListBox1.Items[0], "AAA", "ListBox.SortItems: (nocase, asc) item 0");
  tap.is(ListBox1.Items[1], "aaa", "ListBox.SortItems: (nocase, asc) item 1");
  tap.is(ListBox1.Items[2], "BBB", "ListBox.SortItems: (nocase, asc) item 2");
  tap.is(ListBox1.Items[3], "bbb", "ListBox.SortItems: (nocase, asc) item 3");
  tap.is(ListBox1.Items[4], "CCC", "ListBox.SortItems: (nocase, asc) item 4");
  tap.is(ListBox1.Items[5], "ccc", "ListBox.SortItems: (nocase, asc) item 5");
  
  FillListBox(ListBox1);
  ListBox1.SortItems(eCaseInsensitive, eSortDescending);
  tap.is_int(ListBox1.ItemCount, 6, "ListBox.SortItems: (nocase, dsc) item count");
  tap.is(ListBox1.Items[0], "CCC", "ListBox.SortItems: (nocase, dsc) item 0");
  tap.is(ListBox1.Items[1], "ccc", "ListBox.SortItems: (nocase, dsc) item 1");
  tap.is(ListBox1.Items[2], "BBB", "ListBox.SortItems: (nocase, dsc) item 2");
  tap.is(ListBox1.Items[3], "bbb", "ListBox.SortItems: (nocase, dsc) item 3");
  tap.is(ListBox1.Items[4], "AAA", "ListBox.SortItems: (nocase, dsc) item 4");
  tap.is(ListBox1.Items[5], "aaa", "ListBox.SortItems: (nocase, dsc) item 5");
}

void TestFrameAudio()
{
  gGui1.Visible = true;
  Button1.Visible = true;
  Button1.Animate(VFRAME_AUDIO, 0, 4, eOnce, eNoBlock, eForwards, 0, 50);
  
  tap.ok(!System.AudioChannels[0].IsPlaying && System.AudioChannels[0].PlayingClip == null, "Button: FrameAudio: initial audio state");
  
  int last_frame = -1;
  LastInteraction = "";
  while (Button1.Animating)
  {
    if (last_frame != Button1.Frame)
    {
      if (Button1.Frame == 3)
      {
        tap.ok(System.AudioChannels[1].IsPlaying && System.AudioChannels[1].PlayingClip == aSilence_1sec_02 && System.AudioChannels[1].Position == 0, 
          "Button: FrameAudio: frame 3 sound started");
        tap.ok(System.AudioChannels[1].Volume == 50, "Button: FrameAudio: frame 3 sound: volume match Animate volume");
      }
      else if (Button1.Frame == 13)
      {
        tap.ok(System.AudioChannels[1].IsPlaying && System.AudioChannels[1].PlayingClip == aSilence_1sec_02 && System.AudioChannels[1].Position == 0,
          "Button: FrameAudio: frame 13 sound started");
        tap.ok(System.AudioChannels[1].Volume == 50, "Button: FrameAudio: frame 13 sound: volume match Animate volume");
      }
      
      if (Button1.Frame == 1)
      {
        tap.ok(LastInteraction == "Button.OnFrameEvent: event1", "Button: OnFrameEvent event1");
      }
      else if (Button1.Frame == 8)
      {
        tap.ok(LastInteraction == "Button.OnFrameEvent: event2", "Button: OnFrameEvent event2");
      }
      else if (Button1.Frame == 14)
      {
        tap.ok(LastInteraction == "Button.OnFrameEvent: event3", "Button: OnFrameEvent event3");
      }
    }
    last_frame = Button1.Frame;
    LastInteraction = "";
    Wait(1);
  }
}

void TestGUIOperations()
{
  tap.Comment("start GUI Operations tests");
  
  TestListBoxOperations();
  TestFrameAudio();
  
  // CLEANUP
  TestHelpers.HideGUIs();
  
  tap.Comment("end GUI Operations tests");
}
